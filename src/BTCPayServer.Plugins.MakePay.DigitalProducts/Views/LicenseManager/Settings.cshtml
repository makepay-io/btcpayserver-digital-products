@model LicenseManagerSettings
@{
    var storeId = ViewData["StoreId"]?.ToString();
    ViewData.SetActivePage("DigitalDownloads", "Digital Products", "License API & delivery");
}

<div class="sticky-header d-flex justify-content-between align-items-center gap-3 flex-wrap">
    <div>
        <div class="small text-muted"><a asp-controller="DigitalDownloadsAdmin" asp-action="Index" asp-route-storeId="@storeId" asp-route-section="licenses">Digital products</a> / License keys</div>
        <h2 class="mb-0">License API &amp; delivery</h2>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-secondary" asp-controller="DigitalDownloadsAdmin" asp-action="Index" asp-route-storeId="@storeId" asp-route-section="licenses">Back</a>
        <button class="btn btn-primary" type="submit" form="license-settings-form">Save settings</button>
    </div>
</div>

<partial name="_StatusMessage" />
@if (TempData["LicenseApiSecret"] is string secret)
{
    <div class="alert alert-warning"><strong>New API secret — copy it now:</strong><br /><code class="user-select-all">@secret</code></div>
}

<form id="license-settings-form" method="post" asp-controller="LicenseManagerAdmin" asp-action="SaveSettings" asp-route-storeId="@storeId">
    @if (ViewData.ModelState.ErrorCount > 0)
    {
        <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
    }
    <div class="row g-4">
        <div class="col-lg-6">
            <section class="bg-tile rounded p-4">
                <h3 class="h5">Storefront</h3>
                <div class="form-group"><label asp-for="StorefrontTitle" class="form-label"></label><input asp-for="StorefrontTitle" class="form-control" /></div>
                <div class="form-group"><label asp-for="StorefrontDescription" class="form-label"></label><textarea asp-for="StorefrontDescription" class="form-control"></textarea></div>
                <div class="row g-3">
                    <div class="col"><label asp-for="Currency" class="form-label"></label><input asp-for="Currency" class="form-control" /></div>
                    <div class="col"><label asp-for="AccentColor" class="form-label"></label><input asp-for="AccentColor" type="color" class="form-control form-control-color" /></div>
                </div>
                <div class="form-group"><label asp-for="LogoUrl" class="form-label"></label><input asp-for="LogoUrl" class="form-control" /></div>
                <div class="form-group"><label asp-for="FaviconUrl" class="form-label">Favicon URL</label><input asp-for="FaviconUrl" class="form-control" placeholder="https://example.com/favicon.png" /><div class="form-text">Browser-tab icon for the legacy license order page. Use an HTTP(S) PNG or ICO URL; leave blank to emit no custom favicon.</div></div>
            </section>
            <section class="bg-tile rounded p-4 mt-4">
                <h3 class="h5">Email</h3>
                <div class="form-check"><input asp-for="EmailDeliveryEnabled" class="form-check-input" /><label asp-for="EmailDeliveryEnabled" class="form-check-label">Deliver through BTCPay SMTP</label></div>
                <div class="form-group mt-3"><label asp-for="EmailSubject" class="form-label"></label><input asp-for="EmailSubject" class="form-control" /></div>
                <div class="form-group"><label asp-for="EmailHtml" class="form-label"></label><textarea asp-for="EmailHtml" rows="8" class="form-control font-monospace"></textarea></div>
            </section>
        </div>
        <div class="col-lg-6">
            <section class="bg-tile rounded p-4">
                <h3 class="h5">Signed verification API</h3>
                <div class="form-check"><input asp-for="RequireSignedRequests" class="form-check-input" /><label asp-for="RequireSignedRequests" class="form-check-label">Require HMAC signatures</label></div>
                <div class="row g-3 mt-1">
                    <div class="col"><label asp-for="LicenseKeyHeader" class="form-label"></label><input asp-for="LicenseKeyHeader" class="form-control" /></div>
                    <div class="col"><label asp-for="SignatureHeader" class="form-label"></label><input asp-for="SignatureHeader" class="form-control" /></div>
                </div>
                <div class="row g-3">
                    <div class="col"><label asp-for="TimestampHeader" class="form-label"></label><input asp-for="TimestampHeader" class="form-control" /></div>
                    <div class="col"><label asp-for="NonceHeader" class="form-label"></label><input asp-for="NonceHeader" class="form-control" /></div>
                </div>
                <div class="form-group"><label asp-for="ResponseSignatureHeader" class="form-label"></label><input asp-for="ResponseSignatureHeader" class="form-control" /></div>
                <div class="row g-3">
                    <div class="col"><label asp-for="MaxClockSkewSeconds" class="form-label"></label><input asp-for="MaxClockSkewSeconds" class="form-control" /></div>
                    <div class="col"><label asp-for="RequestsPerMinute" class="form-label"></label><input asp-for="RequestsPerMinute" class="form-control" /></div>
                </div>
                <div class="form-group"><label class="form-label">Set API secret</label><input name="apiSecret" type="password" autocomplete="new-password" class="form-control" placeholder="Leave blank to keep existing" /></div>
                <p class="small text-muted mb-0">Canonical request: timestamp + newline + nonce + newline + action + newline + normalized license key + newline + instanceId.</p>
            </section>
        </div>
    </div>
</form>

<form method="post" asp-controller="LicenseManagerAdmin" asp-action="GenerateSecret" asp-route-storeId="@storeId" class="mt-3">
    <button class="btn btn-outline-warning" type="submit">Generate and replace API secret</button>
</form>
