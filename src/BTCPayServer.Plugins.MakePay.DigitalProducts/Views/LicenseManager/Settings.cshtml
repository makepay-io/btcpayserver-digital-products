@model LicenseManagerSettings
@{var storeId=ViewData["StoreId"]?.ToString();}
<h2>License API & delivery</h2><partial name="_StatusMessage" />
@if(TempData["LicenseApiSecret"] is string secret){<div class="alert alert-warning"><strong>New API secret — copy it now:</strong><br><code class="user-select-all">@secret</code></div>}
<form method="post" asp-action="SaveSettings" asp-route-storeId="@storeId"><div asp-validation-summary="All" class="text-danger"></div><div class="row g-4"><div class="col-lg-6"><div class="bg-tile rounded p-4"><h4>Storefront</h4><div class="form-group"><label asp-for="StorefrontTitle" class="form-label"></label><input asp-for="StorefrontTitle" class="form-control"></div><div class="form-group"><label asp-for="StorefrontDescription" class="form-label"></label><textarea asp-for="StorefrontDescription" class="form-control"></textarea></div><div class="row"><div class="col"><label asp-for="Currency" class="form-label"></label><input asp-for="Currency" class="form-control"></div><div class="col"><label asp-for="AccentColor" class="form-label"></label><input asp-for="AccentColor" type="color" class="form-control form-control-color"></div></div><div class="form-group"><label asp-for="LogoUrl" class="form-label"></label><input asp-for="LogoUrl" class="form-control"></div></div><div class="bg-tile rounded p-4 mt-4"><h4>Email</h4><div class="form-check"><input asp-for="EmailDeliveryEnabled" class="form-check-input"><label asp-for="EmailDeliveryEnabled" class="form-check-label">Deliver through BTCPay SMTP</label></div><div class="form-group mt-3"><label asp-for="EmailSubject" class="form-label"></label><input asp-for="EmailSubject" class="form-control"></div><div class="form-group"><label asp-for="EmailHtml" class="form-label"></label><textarea asp-for="EmailHtml" rows="8" class="form-control font-monospace"></textarea></div></div></div><div class="col-lg-6"><div class="bg-tile rounded p-4"><h4>Signed verification API</h4><div class="form-check"><input asp-for="RequireSignedRequests" class="form-check-input"><label asp-for="RequireSignedRequests" class="form-check-label">Require HMAC signatures</label></div><div class="row mt-3"><div class="col"><label asp-for="LicenseKeyHeader" class="form-label"></label><input asp-for="LicenseKeyHeader" class="form-control"></div><div class="col"><label asp-for="SignatureHeader" class="form-label"></label><input asp-for="SignatureHeader" class="form-control"></div></div><div class="row"><div class="col"><label asp-for="TimestampHeader" class="form-label"></label><input asp-for="TimestampHeader" class="form-control"></div><div class="col"><label asp-for="NonceHeader" class="form-label"></label><input asp-for="NonceHeader" class="form-control"></div></div><div class="form-group"><label asp-for="ResponseSignatureHeader" class="form-label"></label><input asp-for="ResponseSignatureHeader" class="form-control"></div><div class="row"><div class="col"><label asp-for="MaxClockSkewSeconds" class="form-label"></label><input asp-for="MaxClockSkewSeconds" class="form-control"></div><div class="col"><label asp-for="RequestsPerMinute" class="form-label"></label><input asp-for="RequestsPerMinute" class="form-control"></div></div><div class="form-group"><label class="form-label">Set API secret</label><input name="apiSecret" type="password" autocomplete="new-password" class="form-control" placeholder="Leave blank to keep existing"></div><p class="small text-muted">Canonical request: timestamp + newline + nonce + newline + action + newline + normalized license key + newline + instanceId.</p></div></div></div><button class="btn btn-primary mt-4">Save settings</button> <a class="btn btn-secondary mt-4" asp-action="Index" asp-route-storeId="@storeId">Back</a></form>
<form method="post" asp-action="GenerateSecret" asp-route-storeId="@storeId" class="mt-3"><button class="btn btn-outline-warning">Generate and replace API secret</button></form>
