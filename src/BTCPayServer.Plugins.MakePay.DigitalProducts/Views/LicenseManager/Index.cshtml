@model LicenseDashboardViewModel
@{ ViewData.SetActivePage("DigitalDownloads", "Digital Products", "License keys"); }
<div class="sticky-header d-flex justify-content-between align-items-center"><div><h2 class="mb-0">Digital Products</h2><div class="text-muted">License keys</div></div><div class="d-flex gap-2"><a class="btn btn-secondary" target="_blank" asp-controller="DigitalDownloadsPublic" asp-action="Storefront" asp-route-storeId="@Model.StoreId">View store</a><a class="btn btn-secondary" asp-action="Settings" asp-route-storeId="@Model.StoreId">API & email</a><a class="btn btn-primary" asp-action="Product" asp-route-storeId="@Model.StoreId">Add product</a></div></div>
<nav class="nav nav-pills gap-2 mb-4" aria-label="Digital product sections"><a class="nav-link" asp-controller="DigitalDownloadsAdmin" asp-action="Index" asp-route-storeId="@Model.StoreId">Downloads</a><a class="nav-link active" aria-current="page" asp-controller="LicenseManagerAdmin" asp-action="Index" asp-route-storeId="@Model.StoreId">License keys</a></nav>
<partial name="_StatusMessage" />
@if(TempData["IssuedLicenseKey"] is string issued){<div class="alert alert-success"><strong>Issued key (copy now):</strong> <code class="user-select-all">@issued</code></div>}
<div class="row g-3 mb-4"><div class="col"><div class="bg-tile rounded p-3"><div class="text-muted">Products</div><div class="h3">@Model.Products.Count</div></div></div><div class="col"><div class="bg-tile rounded p-3"><div class="text-muted">Active licenses</div><div class="h3">@Model.Licenses.Count(l => l.Status == ManagedLicenseStatus.Active)</div></div></div><div class="col"><div class="bg-tile rounded p-3"><div class="text-muted">Activations</div><div class="h3">@Model.Licenses.Sum(l => l.Activations.Count)</div></div></div></div>
<h4>Products</h4><div class="table-responsive mb-4"><table class="table"><thead><tr><th>Name</th><th>Pattern</th><th>Activations</th><th></th></tr></thead><tbody>@foreach(var p in Model.Products){<tr><td>@p.Name</td><td><code>@p.KeyPattern</code></td><td>@p.MaxActivations</td><td class="text-end"><a class="btn btn-sm btn-secondary" asp-action="Product" asp-route-storeId="@Model.StoreId" asp-route-productId="@p.Id">Edit</a></td></tr>}</tbody></table></div>
<div class="bg-tile rounded p-4 mb-4"><h4>Issue manually</h4><form method="post" asp-action="Issue" asp-route-storeId="@Model.StoreId" class="row g-2"><div class="col-md-5"><select name="productId" class="form-select" required>@foreach(var p in Model.Products){<option value="@p.Id">@p.Name</option>}</select></div><div class="col-md-5"><input name="email" type="email" class="form-control" required placeholder="customer@example.com"></div><div class="col-md-2"><button class="btn btn-primary w-100">Issue</button></div></form></div>
<h4>Licenses</h4><div class="table-responsive"><table class="table align-middle"><thead><tr><th>Issued</th><th>Customer</th><th>Product</th><th>Status</th><th>Activations</th><th>Action</th></tr></thead><tbody>@foreach(var l in Model.Licenses){<tr><td>@l.IssuedAt.ToBrowserDate()</td><td>@l.CustomerEmail<div class="small text-muted"><code>@l.Id[..10]</code></div></td><td>@Model.Products.FirstOrDefault(p=>p.Id==l.ProductId)?.Name</td><td>@l.Status</td><td>@l.Activations.Count / @l.MaxActivations</td><td><form method="post" asp-action="Status" asp-route-storeId="@Model.StoreId" asp-route-licenseId="@l.Id"><select name="status" class="form-select form-select-sm" onchange="this.form.submit()" asp-items="Html.GetEnumSelectList<ManagedLicenseStatus>()"><option value="">Change…</option></select></form></td></tr>}</tbody></table></div>
<div class="alert alert-info">@Model.Settings.PromotionText <a href="https://makepay.io" target="_blank" rel="noopener">Enable MakePay multicurrency</a>.</div>
