@model LicenseProduct
@{ var storeId=ViewData["StoreId"]?.ToString(); }
<h2>@Model.Name</h2><form method="post" asp-action="SaveProduct" asp-route-storeId="@storeId" asp-route-productId="@Model.Id"><div asp-validation-summary="All" class="text-danger"></div><div class="row g-4"><div class="col-lg-7"><div class="form-group"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control"></div><div class="form-group"><label asp-for="Slug" class="form-label"></label><input asp-for="Slug" class="form-control"></div><div class="form-group"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" rows="6" class="form-control"></textarea></div><div class="row"><div class="col"><label asp-for="Price" class="form-label"></label><input asp-for="Price" class="form-control"></div><div class="col"><label asp-for="ImageUrl" class="form-label"></label><input asp-for="ImageUrl" class="form-control"></div></div></div><div class="col-lg-5"><div class="bg-tile rounded p-4"><h4>License policy</h4><div class="form-group"><label asp-for="KeyPattern" class="form-label"></label><input asp-for="KeyPattern" class="form-control font-monospace"><div class="form-text">Tokens: {A:4}, {N:4}, {X:8}, {HEX:8}, {YEAR}</div></div><div class="row"><div class="col"><label asp-for="MaxActivations" class="form-label"></label><input asp-for="MaxActivations" class="form-control"></div><div class="col"><label asp-for="DurationDays" class="form-label"></label><input asp-for="DurationDays" class="form-control" placeholder="Blank = lifetime"></div></div><div class="form-check mt-3"><input asp-for="Active" class="form-check-input"><label asp-for="Active" class="form-check-label">Published</label></div></div></div></div><button class="btn btn-primary mt-4">Save product</button> <a class="btn btn-secondary mt-4" asp-action="Index" asp-route-storeId="@storeId">Cancel</a></form>
