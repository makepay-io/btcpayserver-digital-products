@model LicenseProduct
@{
    var storeId = ViewData["StoreId"]?.ToString();
    var routeProductId = ViewContext.RouteData.Values["productId"]?.ToString();
    var isNew = string.IsNullOrWhiteSpace(routeProductId) || routeProductId == "new";
    var saveProductId = isNew ? "new" : Model.Id;
    ViewData.SetActivePage("DigitalDownloads", "Digital Products", isNew ? "New license product" : Model.Name);
}

<div class="sticky-header d-flex justify-content-between align-items-center gap-3 flex-wrap">
    <div>
        <div class="small text-muted"><a asp-controller="DigitalDownloadsAdmin" asp-action="Index" asp-route-storeId="@storeId" asp-route-section="licenses">Digital products</a> / License keys</div>
        <h2 class="mb-0">@(isNew ? "Create license product" : Model.Name)</h2>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-secondary" asp-controller="DigitalDownloadsAdmin" asp-action="Index" asp-route-storeId="@storeId" asp-route-section="licenses">Cancel</a>
        <button class="btn btn-primary" type="submit" form="license-product-form">Save product</button>
    </div>
</div>

<partial name="_StatusMessage" />
<form id="license-product-form" method="post" asp-controller="LicenseManagerAdmin" asp-action="SaveProduct" asp-route-storeId="@storeId" asp-route-productId="@saveProductId">
    @if (ViewData.ModelState.ErrorCount > 0)
    {
        <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
    }
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="bg-tile rounded p-4 h-100">
                <h3 class="h5">Store listing</h3>
                <div class="form-group"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger"></span></div>
                <div class="form-group"><label asp-for="Slug" class="form-label"></label><input asp-for="Slug" class="form-control" /><span asp-validation-for="Slug" class="text-danger"></span></div>
                <div class="form-group"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" rows="6" class="form-control"></textarea></div>
                <div class="row g-3">
                    <div class="col-md-4 form-group"><label asp-for="Price" class="form-label"></label><input asp-for="Price" class="form-control" /><span asp-validation-for="Price" class="text-danger"></span></div>
                    <div class="col-md-4 form-group"><label asp-for="CompareAtPrice" class="form-label">Compare-at price</label><input asp-for="CompareAtPrice" class="form-control" placeholder="Optional" /></div>
                    <div class="col-md-4 form-group"><label asp-for="Badge" class="form-label">Badge</label><input asp-for="Badge" class="form-control" placeholder="Best value" /></div>
                </div>
                <div class="form-group"><label asp-for="ImageUrl" class="form-label">Cover image URL</label><input asp-for="ImageUrl" class="form-control" /></div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="bg-tile rounded p-4">
                <h3 class="h5">License policy</h3>
                <div class="form-group"><label asp-for="KeyPattern" class="form-label"></label><input asp-for="KeyPattern" class="form-control font-monospace" /><span asp-validation-for="KeyPattern" class="text-danger"></span><div class="form-text">Tokens: {A:4}, {N:4}, {X:8}, {HEX:8}, {YEAR}</div></div>
                <div class="row g-3">
                    <div class="col"><label asp-for="MaxActivations" class="form-label"></label><input asp-for="MaxActivations" class="form-control" /></div>
                    <div class="col"><label asp-for="DurationDays" class="form-label"></label><input asp-for="DurationDays" class="form-control" placeholder="Blank = lifetime" /></div>
                </div>
                <div class="form-check mt-3"><input asp-for="Active" class="form-check-input" /><label asp-for="Active" class="form-check-label">Published</label></div>
            </div>
        </div>
    </div>
</form>
