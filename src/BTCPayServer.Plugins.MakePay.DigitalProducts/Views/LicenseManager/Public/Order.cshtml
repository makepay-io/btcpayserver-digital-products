@model LicenseOrderViewModel
@{
    Layout = null;
    var faviconUrl = DigitalStorefrontBuilder.SafePublicResourceUrl(Model.Settings.FaviconUrl);
}
<!doctype html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width">
    <meta http-equiv="refresh" content="@(Model.Order.Status == LicenseOrderStatus.Pending ? "10" : "")">
    <title>Your license</title>
    @if (faviconUrl is not null)
    {
        <link rel="icon" href="@faviconUrl">
    }
    <style>body{background:#f7f6fb;color:#1f1735;font:16px/1.5 system-ui}.box{max-width:650px;margin:10vh auto;background:#fff;padding:45px;border-radius:22px;text-align:center;box-shadow:0 18px 50px #29165815}.key{padding:18px;background:#f0ecf8;border-radius:12px;font:700 22px monospace;word-break:break-all}.muted{color:#756b89}</style>
</head>
<body>
<main class="box">
    <h1>@Model.Product.Name</h1>
    @if (Model.LicenseKey is not null)
    {
        <p>Payment received. Copy your license key:</p>
        <div class="key">@Model.LicenseKey</div>
        <p class="muted">Expires: @(Model.ExpiresAt?.ToString("u") ?? "Never")</p>
    }
    else
    {
        <p>Waiting for payment confirmation. This page refreshes automatically.</p>
    }
    <p class="muted">@Model.Settings.PromotionText</p>
</main>
</body>
</html>
