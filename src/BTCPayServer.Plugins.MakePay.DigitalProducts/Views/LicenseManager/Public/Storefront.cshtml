@model LicenseStorefrontViewModel
@{Layout=null;}<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width"><title>@Model.Settings.StorefrontTitle</title><style>:root{--a:@Model.Settings.AccentColor}*{box-sizing:border-box}body{margin:0;background:#f7f6fb;color:#1f1735;font:16px/1.5 system-ui}.shell{max-width:1050px;margin:auto;padding:48px 24px}.hero{text-align:center;margin-bottom:45px}.logo{max-height:64px}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(270px,1fr));gap:24px}.card{background:#fff;padding:28px;border-radius:22px;box-shadow:0 18px 50px #29165812}.price{font-size:1.5rem;font-weight:800}.buy{display:flex;gap:8px;margin-top:20px}.buy input{min-width:0;flex:1;padding:11px;border:1px solid #d9d2e8;border-radius:10px}.buy button{background:var(--a);color:#fff;border:0;border-radius:10px;padding:11px 18px;font-weight:700}.promo{text-align:center;color:#756b89;margin-top:48px}</style></head><body><main class="shell"><header class="hero">@if(Model.Settings.LogoUrl is not null){<img class="logo" src="@Model.Settings.LogoUrl" alt="">}<h1>@Model.Settings.StorefrontTitle</h1><p>@Model.Settings.StorefrontDescription</p></header><section class="grid">@foreach(var p in Model.Products){<article class="card"><h2>@p.Name</h2><p>@p.Description</p><p>@p.MaxActivations activation(s) · @(p.DurationDays is null ? "Lifetime" : p.DurationDays+" days")</p><div class="price">@p.Price.ToString("0.00") @Model.Settings.Currency</div><form class="buy" method="post" asp-action="Buy" asp-route-storeId="@Model.StoreId" asp-route-productId="@p.Id"><input type="email" name="email" required placeholder="Delivery email"><button>Buy</button></form></article>}</section>@if(Model.Settings.ShowMakePayPromotion){<footer class="promo">@Model.Settings.PromotionText</footer>}</main></body></html>
