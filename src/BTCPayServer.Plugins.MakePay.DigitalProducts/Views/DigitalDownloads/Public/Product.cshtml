@model DigitalProductDetailViewModel
@{
    Layout = null;
    var product = Model.Product;
    var digitalProduct = Model.DigitalProduct;
    var kind = DigitalStorefrontBuilder.ProductKindSegment(product);
    var typeLabel = DigitalStorefrontBuilder.ProductTypeLabel(product);
    var productImage = product.ImageUrl ?? Url.Action("ProductAsset", "DigitalDownloadsPublic", new { storeId = Model.StoreId, kind = DigitalStorefrontBuilder.ProductAssetKind(product) });
    var returnUrl = Context.Request.Path.ToString() + Context.Request.QueryString.ToString();
    var productReference = DigitalStorefrontBuilder.ProductReference(product);
    var productCategories = Model.Categories.Where(category => category.ProductReferences.Contains(productReference)).ToList();
    var previewAssets = digitalProduct?.PreviewEnabled == true
        ? digitalProduct.PreviewAssets.OrderBy(asset => asset.SortOrder).ThenBy(asset => asset.Label).ToList()
        : [];
    var mediaScriptUrl = Url.Action("Asset", "DigitalDownloadsAssets", new { storeId = Model.StoreId, fileName = "makepay-media.js" });
    var pdfLibraryUrl = Url.Action("Asset", "DigitalDownloadsAssets", new { storeId = Model.StoreId, fileName = "pdf.min.mjs" });
    var pdfWorkerUrl = Url.Action("Asset", "DigitalDownloadsAssets", new { storeId = Model.StoreId, fileName = "pdf.worker.min.mjs" });
    var analytics = new DigitalAnalyticsViewModel { StoreId = Model.StoreId, Settings = Model.Settings, PageType = "product" };
    var itemAnalytics = DigitalAnalyticsBuilder.Product(product, Model.Settings.Currency);
    var itemAnalyticsJson = JsonSerializer.Serialize(itemAnalytics);
    var relatedListAnalytics = DigitalAnalyticsBuilder.Catalog(Model.RelatedProducts, Model.Settings.Currency, "related-products", "You may also like");
    string PreviewUrl(DigitalProductPreviewAsset asset) => Url.Action("ProductPreview", "DigitalDownloadsPublic", new { storeId = Model.StoreId, productId = product.Id, assetId = asset.Id })!;
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="@product.Description">
    <title>@product.Name · @Model.Settings.StorefrontTitle</title>
    <partial name="~/Views/DigitalDownloads/Public/_Theme.cshtml" model="Model.Settings" />
    <partial name="~/Views/DigitalDownloads/Public/_AnalyticsHead.cshtml" model="analytics" />
    <style>
        .dp-detail-market{min-height:100vh;background:var(--dp-page)}.dp-detail-width{width:min(100% - 40px,1380px);margin-inline:auto}
        .dp-detail-promo{min-height:38px;display:grid;place-items:center;padding:8px 20px;background:var(--dp-accent);color:var(--dp-accent-text);font-size:.8rem;font-weight:750;text-align:center}
        .dp-detail-header{border-bottom:1px solid var(--dp-border);background:var(--dp-surface)}.dp-detail-header .dp-detail-width{min-height:72px;display:grid;grid-template-columns:minmax(230px,1fr) auto minmax(230px,1fr);align-items:center;gap:24px}.dp-detail-brand{display:flex;align-items:center;gap:12px;color:var(--dp-accent)!important;text-decoration:none;font-size:.88rem;font-weight:900;letter-spacing:.025em;text-transform:uppercase;min-width:0}.dp-detail-brand img{display:block;width:min(var(--dp-logo-width),100%);height:var(--dp-logo-height);max-width:100%;object-fit:contain;object-position:left center}.dp-detail-nav,.dp-detail-account{display:flex;align-items:center;gap:28px}.dp-detail-nav{justify-content:center}.dp-detail-account{justify-content:flex-end}.dp-detail-nav a,.dp-detail-account>a:not(.dp-primary){color:var(--dp-text)!important;text-decoration:none;font-size:.84rem;font-weight:750}.dp-detail-nav a:hover,.dp-detail-account>a:not(.dp-primary):hover{color:var(--dp-accent)!important}.dp-detail-cart{min-height:42px;padding:9px 15px;border-radius:9px;box-shadow:0 7px 18px color-mix(in srgb,var(--dp-accent) 18%,transparent)}
        .dp-detail-main{padding:30px 0 54px}.dp-detail-breadcrumbs{display:flex;align-items:center;gap:9px;flex-wrap:wrap;margin-bottom:24px;color:var(--dp-muted);font-size:.8rem}.dp-detail-breadcrumbs a{color:var(--dp-muted)!important;text-decoration:none}.dp-detail-breadcrumbs a:hover{color:var(--dp-accent)!important}.dp-detail-layout{display:grid;grid-template-columns:minmax(360px,.92fr) minmax(430px,1.08fr);gap:64px;align-items:center}.dp-detail-media{position:relative;display:grid;place-items:center;min-height:570px;padding:46px;border:1px solid var(--dp-border);border-radius:20px;background:var(--dp-soft);overflow:hidden}.dp-detail-media img{display:block;width:100%;height:480px;object-fit:contain;object-position:center;filter:drop-shadow(0 22px 28px rgba(16,24,40,.14));image-rendering:-webkit-optimize-contrast}.dp-detail-preview-flag{position:absolute;left:18px;top:18px;display:inline-flex;align-items:center;min-height:34px;padding:7px 11px;border:1px solid color-mix(in srgb,var(--dp-accent) 25%,var(--dp-border));border-radius:999px;background:color-mix(in srgb,var(--dp-surface) 94%,transparent);color:var(--dp-accent);font-size:.7rem;font-weight:850;text-decoration:none;box-shadow:0 5px 16px rgba(16,24,40,.08)}.dp-detail-copy{max-width:650px}.dp-detail-copy .dp-product-type{margin-bottom:12px}.dp-detail-badge{display:inline-flex;margin-bottom:12px;padding:6px 10px;border-radius:999px;background:color-mix(in srgb,var(--dp-accent) 10%,var(--dp-surface));color:var(--dp-accent);font-size:.72rem;font-weight:850;letter-spacing:.05em;text-transform:uppercase}.dp-detail-copy h1{margin:0;font-size:clamp(2.6rem,4.6vw,4.9rem);line-height:.94;letter-spacing:-.055em;overflow-wrap:anywhere}.dp-detail-byline{margin:18px 0 0;color:var(--dp-muted);font-size:.92rem;font-weight:700}.dp-detail-description{margin:19px 0 0;color:var(--dp-muted);font-size:1.05rem;white-space:pre-line}.dp-detail-meta{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:28px 0}.dp-detail-meta div{padding:16px 18px;border:1px solid var(--dp-border);border-radius:12px;background:var(--dp-surface)}.dp-detail-meta span{display:block;color:var(--dp-muted);font-size:.72rem;font-weight:750;letter-spacing:.06em;text-transform:uppercase}.dp-detail-meta strong{display:block;margin-top:4px;font-size:.9rem}.dp-detail-purchase{display:flex;align-items:end;justify-content:space-between;gap:24px;padding-top:24px;border-top:1px solid var(--dp-border)}.dp-detail-price{font-size:1.75rem;font-weight:900;letter-spacing:-.025em;white-space:nowrap}.dp-detail-old-price{display:block;color:var(--dp-muted);font-size:.84rem;font-weight:650;text-decoration:line-through}.dp-detail-form{display:flex;align-items:end;gap:10px}.dp-detail-quantity{display:flex;flex-direction:column;gap:5px}.dp-detail-quantity label{color:var(--dp-muted);font-size:.72rem;font-weight:750;text-transform:uppercase}.dp-detail-quantity input{width:72px;min-height:46px;border:1px solid var(--dp-border);border-radius:10px;background:var(--dp-surface);color:var(--dp-text);padding:10px}.dp-detail-assurance{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:48px}.dp-detail-assurance article{padding:20px;border:1px solid var(--dp-border);border-radius:14px;background:var(--dp-surface)}.dp-detail-assurance h2{margin:0 0 7px;font-size:.95rem}.dp-detail-assurance p{margin:0;color:var(--dp-muted);font-size:.82rem}
        .dp-detail-related{margin-top:64px;padding-top:34px;border-top:1px solid var(--dp-border)}.dp-detail-related>header{display:flex;align-items:end;justify-content:space-between;gap:20px;margin-bottom:18px}.dp-detail-related h2{margin:0;font-size:1.65rem;letter-spacing:-.035em}.dp-detail-related>header a{font-size:.84rem;font-weight:800;text-decoration:none}.dp-detail-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:18px}.dp-detail-card{display:grid;grid-template-columns:116px minmax(0,1fr);gap:16px;padding:14px;border:1px solid var(--dp-border);border-radius:15px;background:var(--dp-surface);text-decoration:none}.dp-detail-card:hover{border-color:color-mix(in srgb,var(--dp-accent) 45%,var(--dp-border));box-shadow:0 10px 28px rgba(16,24,40,.07)}.dp-detail-card img{display:block;width:116px;height:150px;border-radius:8px;background:#071d45;object-fit:contain}.dp-detail-card .dp-product-type{margin:4px 0 7px}.dp-detail-card h3{margin:0;color:var(--dp-text);font-size:1rem;line-height:1.2}.dp-detail-card p{margin:9px 0;color:var(--dp-muted);font-size:.8rem}.dp-detail-card strong{display:block;margin-top:12px;color:var(--dp-text)}
        .dp-detail-footer{padding:32px 0 18px;background:#0d1b32;color:#dbe4f2}.dp-detail-footer a{color:#dbe4f2!important;text-decoration-color:rgba(219,228,242,.45);text-underline-offset:3px}.dp-detail-footer a:hover{color:#fff!important;text-decoration-color:#fff}.dp-detail-footer-grid{display:grid;grid-template-columns:1.45fr .85fr .85fr;gap:52px}.dp-detail-footer h2,.dp-detail-footer h3{color:#fff;text-transform:uppercase;letter-spacing:.08em}.dp-detail-footer h2{font-size:.82rem;color:#6f9cff}.dp-detail-footer h3{font-size:.73rem;margin:0 0 16px}.dp-detail-footer p,.dp-detail-footer li,.dp-detail-footer a{font-size:.82rem}.dp-detail-footer ul{list-style:none;padding:0;margin:0}.dp-detail-footer li{margin:9px 0}.dp-detail-powered{margin-top:18px}.dp-detail-powered>span{display:block;margin-bottom:12px;color:#aebbd0;font-size:.72rem;font-weight:750;letter-spacing:.05em;text-transform:uppercase}.dp-detail-powered-logos{display:flex;align-items:center;gap:24px;min-height:38px}.dp-detail-powered-logos a{display:inline-flex;align-items:center;min-height:38px;padding:0;border:0;text-decoration:none}.dp-detail-powered-logos img{display:block;width:126px;height:32px;object-fit:contain;object-position:left center}.dp-detail-makepay{color:#fff!important;font-size:1.2rem!important;font-weight:700;letter-spacing:-.025em;line-height:1;white-space:nowrap}.dp-detail-footer-bottom{display:flex;justify-content:space-between;gap:24px;margin-top:24px;padding-top:18px;border-top:1px solid rgba(255,255,255,.12);color:#aebbd0;font-size:.75rem}.dp-detail-footer-bottom a{font-weight:750}
        @@media(max-width:1050px){.dp-detail-header .dp-detail-width{grid-template-columns:1fr auto}.dp-detail-nav{display:none}.dp-detail-layout{grid-template-columns:minmax(300px,.9fr) minmax(360px,1.1fr);gap:36px}.dp-detail-media{min-height:480px}.dp-detail-media img{height:400px}.dp-detail-footer-grid{grid-template-columns:1.3fr 1fr 1fr}}
        @@media(max-width:760px){.dp-detail-width{width:min(100% - 28px,1380px)}.dp-detail-header .dp-detail-width{min-height:66px;gap:14px}.dp-detail-account{gap:10px}.dp-detail-account>a:not(.dp-detail-cart){display:none}.dp-detail-brand{font-size:.72rem}.dp-detail-layout{grid-template-columns:1fr}.dp-detail-media{min-height:360px;padding:24px}.dp-detail-media img{height:310px}.dp-detail-copy h1{font-size:3rem}.dp-detail-meta{grid-template-columns:1fr}.dp-detail-purchase{align-items:stretch;flex-direction:column}.dp-detail-form{align-items:stretch}.dp-detail-form .dp-primary{flex:1}.dp-detail-assurance{grid-template-columns:1fr}.dp-detail-grid{grid-template-columns:1fr}.dp-detail-footer-grid{grid-template-columns:1fr 1fr}.dp-detail-footer-grid>div:first-child{grid-column:1/-1}.dp-detail-footer-bottom{flex-direction:column}}
        @@media(max-width:430px){.dp-detail-copy h1{font-size:2.55rem}.dp-detail-card{grid-template-columns:94px minmax(0,1fr)}.dp-detail-card img{width:94px;height:122px}.dp-detail-footer-grid{grid-template-columns:1fr}.dp-detail-footer-grid>div{grid-column:auto!important}}
    </style>
</head>
<body class="dp-public">
<div class="dp-detail-market">
    @if (!string.IsNullOrWhiteSpace(Model.Settings.StorefrontAnnouncement))
    {
        <div class="dp-detail-promo">@Model.Settings.StorefrontAnnouncement</div>
    }
    <header class="dp-detail-header"><div class="dp-detail-width">
        <a class="dp-detail-brand" asp-action="Storefront" asp-route-storeId="@Model.StoreId" style="--dp-logo-width:@(Model.Settings.LogoWidth)px;--dp-logo-height:@(Model.Settings.LogoHeight)px">@if(!string.IsNullOrWhiteSpace(Model.Settings.LogoUrl)){<img src="@Model.Settings.LogoUrl" alt="@Model.Settings.StorefrontTitle">}else{@Model.Settings.StorefrontTitle}</a>
        <nav class="dp-detail-nav" aria-label="Store navigation"><a asp-action="Storefront" asp-route-storeId="@Model.StoreId">Shop</a>@foreach(var category in Model.Categories.Take(5)){<a asp-action="Storefront" asp-route-storeId="@Model.StoreId" asp-route-category="@category.Slug">@category.Name</a>}</nav>
        <nav class="dp-detail-account" aria-label="Customer navigation"><a asp-action="Account" asp-route-storeId="@Model.StoreId">@(Model.CustomerEmail is null ? "Sign in" : "Purchases")</a><a class="dp-primary dp-detail-cart" asp-action="CartPage" asp-route-storeId="@Model.StoreId">Cart · @Model.CartCount</a></nav>
    </div></header>
    <main class="dp-detail-main"><div class="dp-detail-width">
        <nav class="dp-detail-breadcrumbs" aria-label="Breadcrumb"><a asp-action="Storefront" asp-route-storeId="@Model.StoreId">Shop</a><span>/</span>@if(productCategories.Count>0){<a asp-action="Storefront" asp-route-storeId="@Model.StoreId" asp-route-category="@productCategories[0].Slug">@productCategories[0].Name</a><span>/</span>}<span>@product.Name</span></nav>
        <section class="dp-detail-layout">
            <div class="dp-detail-media"><img src="@productImage" alt="@product.Name" width="900" height="1100" decoding="async">@if(previewAssets.Count>0){<a class="dp-detail-preview-flag" href="#preview">@DigitalStorefrontBuilder.PreviewActionLabel(digitalProduct!.ProductType)</a>}</div>
            <div class="dp-detail-copy">
                <div class="dp-product-type">@typeLabel</div>
                @if(!string.IsNullOrWhiteSpace(product.Badge)){<div class="dp-detail-badge">@product.Badge</div>}
                <h1>@product.Name</h1>
                @if(digitalProduct is not null && (!string.IsNullOrWhiteSpace(digitalProduct.Creator) || !string.IsNullOrWhiteSpace(digitalProduct.Edition))){<p class="dp-detail-byline">@if(!string.IsNullOrWhiteSpace(digitalProduct.Creator)){<span>By @digitalProduct.Creator</span>}@if(!string.IsNullOrWhiteSpace(digitalProduct.Creator) && !string.IsNullOrWhiteSpace(digitalProduct.Edition)){<span> · </span>}@if(!string.IsNullOrWhiteSpace(digitalProduct.Edition)){<span>@digitalProduct.Edition</span>}</p>}
                <p class="dp-detail-description">@product.Description</p>
                <div class="dp-detail-meta"><div><span>Delivery</span><strong>@(digitalProduct is null ? "License key after payment" : DigitalStorefrontBuilder.DeliveryLabel(digitalProduct))</strong></div><div><span>Details</span><strong>@product.Meta</strong></div>@if(digitalProduct is not null && !string.IsNullOrWhiteSpace(digitalProduct.MediaDetails)){<div><span>Format</span><strong>@digitalProduct.MediaDetails</strong></div>}@if(previewAssets.Count>0){<div><span>Preview</span><strong>@previewAssets.Count public sample@(previewAssets.Count==1?"":"s")</strong></div>}</div>
                <div class="dp-detail-purchase"><div>@if(product.CompareAtPrice is not null){<span class="dp-detail-old-price">@product.CompareAtPrice.Value.ToString("0.00") @Model.Settings.Currency</span>}<div class="dp-detail-price">@product.Price.ToString("0.00") @Model.Settings.Currency</div></div><form class="dp-detail-form" method="post" asp-action="AddToCart" asp-route-storeId="@Model.StoreId" data-loading-title="Adding to cart…" data-makepay-analytics-form="add_to_cart" data-makepay-analytics-payload="@itemAnalyticsJson"><input type="hidden" name="kind" value="@product.Kind"><input type="hidden" name="productId" value="@product.Id"><input type="hidden" name="returnUrl" value="@returnUrl">@if(product.Kind==DigitalProductKind.License){<div class="dp-detail-quantity"><label for="quantity">Quantity</label><input id="quantity" type="number" name="quantity" value="1" min="1" max="10" inputmode="numeric"></div>}else{<input type="hidden" name="quantity" value="1">}<button class="dp-primary" type="submit">Add to cart</button></form></div>
            </div>
        </section>
        @if(previewAssets.Count>0 && digitalProduct is not null)
        {
            var firstPreview = previewAssets[0];
            var firstPreviewUrl = PreviewUrl(firstPreview);
            <section class="dp-preview-section" id="preview" aria-labelledby="preview-heading">
                <header class="dp-preview-heading"><div><p class="dp-eyebrow">Public sample</p><h2 id="preview-heading">@digitalProduct.PreviewHeading</h2><p>Explore the sample before buying. The protected full product is delivered only after payment.</p></div><span class="dp-preview-note">@DigitalStorefrontBuilder.PreviewActionLabel(digitalProduct.ProductType)</span></header>
                @if(digitalProduct.ProductType == DigitalProductType.PdfEbook || firstPreview.ContentType.Equals("application/pdf", StringComparison.OrdinalIgnoreCase))
                {
                    <div class="dp-pdf-reader" data-pdf-reader data-source="@firstPreviewUrl" data-library="@pdfLibraryUrl" data-worker="@pdfWorkerUrl" tabindex="0" aria-label="PDF book preview">
                        <div class="dp-pdf-toolbar"><div class="dp-pdf-toolbar-group"><button type="button" data-pdf-previous aria-label="Previous page">Previous</button><label class="dp-pdf-page-count">Page <input class="dp-pdf-page-input" type="number" value="1" min="1" data-pdf-page aria-label="Page number"> of <span data-pdf-total>—</span></label><button type="button" data-pdf-next aria-label="Next page">Next</button></div><div class="dp-pdf-toolbar-group"><button type="button" data-pdf-zoom-out aria-label="Zoom out">Zoom out</button><span class="dp-pdf-zoom-value" data-pdf-zoom-value>100%</span><button type="button" data-pdf-zoom-in aria-label="Zoom in">Zoom in</button></div><div class="dp-pdf-toolbar-group"><button type="button" data-pdf-fullscreen>Full screen</button></div></div>
                        <div class="dp-pdf-stage" data-pdf-stage><canvas role="img" aria-label="Current PDF preview page">Your browser does not support the PDF preview canvas.</canvas></div>
                        <p class="dp-pdf-status" data-pdf-status aria-live="polite"><span data-pdf-status-text>Opening preview…</span><a class="dp-pdf-fallback" data-pdf-fallback href="@firstPreviewUrl" target="_blank" rel="noopener noreferrer" hidden>Open PDF directly</a></p>
                    </div>
                }
                else if(digitalProduct.ProductType == DigitalProductType.Audio)
                {
                    <div class="dp-audio-preview"><img src="@productImage" alt="@product.Name cover" width="600" height="600"><div class="dp-audio-copy"><p class="dp-product-type">Demo track</p><h3>@firstPreview.Label</h3><p>Listen to the public audio sample. The full-quality file is delivered according to the purchase option above.</p><audio controls preload="metadata"><source src="@firstPreviewUrl" type="@firstPreview.ContentType">Your browser does not support audio playback. <a href="@firstPreviewUrl">Open the demo file</a>.</audio></div></div>
                }
                else if(digitalProduct.ProductType == DigitalProductType.Video)
                {
                    <div class="dp-video-preview"><video controls playsinline preload="metadata" poster="@productImage"><source src="@firstPreviewUrl" type="@firstPreview.ContentType">Your browser does not support video playback. <a href="@firstPreviewUrl">Open the video preview</a>.</video></div>
                }
                else if(digitalProduct.ProductType == DigitalProductType.PhotosArt || firstPreview.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
                {
                    <div class="dp-photo-gallery" data-photo-gallery><div class="dp-photo-main"><img data-photo-main src="@firstPreviewUrl" alt="@(firstPreview.AltText ?? firstPreview.Label)" width="1400" height="1000"><p class="dp-photo-caption" data-photo-caption>@firstPreview.Label@if(firstPreview.Watermarked){<span> · Watermarked preview</span>}</p></div><div class="dp-photo-thumbs" role="tablist" aria-label="Choose a product preview">@for(var index=0;index<previewAssets.Count;index++){var asset=previewAssets[index];var assetUrl=PreviewUrl(asset);<button class="dp-photo-thumb" type="button" role="tab" data-photo-thumb data-source="@assetUrl" data-label="@asset.Label" data-alt="@(asset.AltText ?? asset.Label)" aria-selected="@(index==0?"true":"false")" aria-label="Show @asset.Label"><img src="@assetUrl" alt="" width="180" height="180" loading="lazy"></button>}</div></div>
                }
                else
                {
                    <div class="dp-file-preview"><img src="@productImage" alt="" width="240" height="300"><div><p class="dp-product-type">Sample included</p><h3>@firstPreview.Label</h3><p>A public sample is available to review before purchasing the protected full download.</p><p><a class="dp-secondary" href="@firstPreviewUrl" target="_blank" rel="noopener noreferrer">Open sample</a></p></div></div>
                }
            </section>
        }
        <section class="dp-detail-assurance" aria-label="Purchase protection"><article><h2>Direct BTCPay checkout</h2><p>Payment is created securely by the plugin backend and opens through BTCPay Server.</p></article><article><h2>Protected fulfillment</h2><p>Private delivery links are issued only after payment confirmation and follow the product’s access settings.</p></article><article><h2>Private purchase library</h2><p>Use passwordless email access to return to digital products, license keys, and purchase history.</p></article></section>
        @if(Model.RelatedProducts.Count>0){<section class="dp-detail-related"><header><h2>You may also like</h2><a asp-action="Storefront" asp-route-storeId="@Model.StoreId">View all products</a></header><div class="dp-detail-grid">@foreach(var related in Model.RelatedProducts){var relatedKind=DigitalStorefrontBuilder.ProductKindSegment(related);var relatedImage=related.ImageUrl??Url.Action("ProductAsset","DigitalDownloadsPublic",new{storeId=Model.StoreId,kind=DigitalStorefrontBuilder.ProductAssetKind(related)});var relatedItemAnalytics=JsonSerializer.Serialize(DigitalAnalyticsBuilder.Product(related,Model.Settings.Currency,listId:"related-products",listName:"You may also like"));<a class="dp-detail-card" asp-action="Product" asp-route-storeId="@Model.StoreId" asp-route-kind="@relatedKind" asp-route-productId="@related.Slug" data-makepay-analytics-click="select_item" data-makepay-analytics-payload="@relatedItemAnalytics"><img src="@relatedImage" alt="@related.Name" width="500" height="650" loading="lazy"><div><div class="dp-product-type">@DigitalStorefrontBuilder.ProductTypeLabel(related)</div><h3>@related.Name</h3><p>@related.Meta</p><strong>@related.Price.ToString("0.00") @Model.Settings.Currency</strong></div></a>}</div></section>}
    </div></main>
    <footer class="dp-detail-footer"><div class="dp-detail-width"><div class="dp-detail-footer-grid"><div><h2>@Model.Settings.StorefrontTitle</h2><p>@Model.Settings.StorefrontDescription</p><div class="dp-detail-powered"><span>Powered by BTCPay &amp; MakePay.io</span><div class="dp-detail-powered-logos"><a href="https://btcpayserver.org" rel="noreferrer" target="_blank" aria-label="Visit BTCPay Server"><img src="/img/btcpay-logo-white-txt.svg" alt="BTCPay Server"></a><a class="dp-detail-makepay" href="https://makepay.io" rel="noreferrer" target="_blank" aria-label="Visit MakePay.io">✦ MakePay</a></div></div></div><div><h3>Shop</h3><ul><li><a asp-action="Storefront" asp-route-storeId="@Model.StoreId">All products</a></li>@foreach(var category in Model.Categories){<li><a asp-action="Storefront" asp-route-storeId="@Model.StoreId" asp-route-category="@category.Slug">@category.Name</a></li>}</ul></div><div><h3>Customer</h3><ul><li><a asp-action="Account" asp-route-storeId="@Model.StoreId">My digital products</a></li><li><a asp-action="Account" asp-route-storeId="@Model.StoreId">My licenses</a></li><li><a asp-action="Account" asp-route-storeId="@Model.StoreId">Sign in</a></li></ul></div></div><div class="dp-detail-footer-bottom"><span>© @DateTime.UtcNow.Year @Model.Settings.StorefrontTitle</span><a href="https://makepay.io" rel="noreferrer" target="_blank">@DigitalStorefrontBuilder.EnforcedPromotionText</a></div></div></footer>
</div>
<script type="application/json" data-makepay-analytics-load="view_item">@Html.Raw(JsonSerializer.Serialize(itemAnalytics))</script>
@if(Model.RelatedProducts.Count>0){<script type="application/json" data-makepay-analytics-load="view_item_list">@Html.Raw(JsonSerializer.Serialize(relatedListAnalytics))</script>}
<partial name="~/Views/DigitalDownloads/Public/_AnalyticsConsent.cshtml" model="analytics" />
@if(previewAssets.Count>0){<script src="@mediaScriptUrl" defer></script>}
</body>
</html>
