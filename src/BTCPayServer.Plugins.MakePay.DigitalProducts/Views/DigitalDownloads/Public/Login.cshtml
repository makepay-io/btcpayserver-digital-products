@model CustomerLoginViewModel
@{ Layout = null; }
<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Sign in · @Model.Settings.StorefrontTitle</title><partial name="~/Views/DigitalDownloads/Public/_Theme.cshtml" model="Model.Settings" /></head><body class="dp-public"><main class="dp-auth-shell"><section class="dp-auth-card"><a class="dp-topbar-brand" asp-action="Storefront" asp-route-storeId="@Model.StoreId">@Model.Settings.StorefrontTitle</a><p class="dp-eyebrow">Private customer access</p><h1>@(Model.CodeSent?"Check your email":"Sign in without a password")</h1><p>@(Model.CodeSent?"Enter the six-digit code we sent. The code expires shortly and can only be used once.":"We’ll email a one-time code so you can check out and return to your purchases later.")</p>@if(Model.Error is not null){<div class="dp-alert" role="alert">@Model.Error</div>}
@if(Model.CodeSent){<form method="post" asp-action="VerifyLoginCode" asp-route-storeId="@Model.StoreId"><input type="hidden" name="returnUrl" value="@Model.ReturnUrl"><div class="dp-field"><label for="login-email">Email</label><input class="dp-input" id="login-email" type="email" name="email" value="@Model.Email" autocomplete="email" required></div><div class="dp-field"><label for="login-code">Six-digit code</label><input class="dp-input dp-code-input" id="login-code" name="code" inputmode="numeric" autocomplete="one-time-code" maxlength="6" pattern="[0-9]{6}" required autofocus></div><button class="dp-primary" type="submit">Confirm and continue</button></form><form method="post" asp-action="RequestLoginCode" asp-route-storeId="@Model.StoreId" style="margin-top:12px"><input type="hidden" name="returnUrl" value="@Model.ReturnUrl"><input type="hidden" name="email" value="@Model.Email"><button class="dp-secondary" style="width:100%" type="submit">Send a new code</button></form>}else{<form method="post" asp-action="RequestLoginCode" asp-route-storeId="@Model.StoreId"><input type="hidden" name="returnUrl" value="@Model.ReturnUrl"><div class="dp-field"><label for="login-email">Email</label><input class="dp-input" id="login-email" type="email" name="email" value="@Model.Email" autocomplete="email" placeholder="you@example.com" required autofocus></div><button class="dp-primary" type="submit">Email my sign-in code</button></form>}
<p class="dp-auth-help">Your email is used for secure delivery and purchase history. No password is stored.</p></section></main></body></html>
