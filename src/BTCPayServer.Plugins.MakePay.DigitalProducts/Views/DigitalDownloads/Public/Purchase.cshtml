@model DigitalPurchaseViewModel
@{
    Layout = null;
    ViewData["StoreId"] = Model.StoreId;
    var waiting = Model.Checkout.Status is DigitalCheckoutStatus.Pending or DigitalCheckoutStatus.Processing;
    var mediaScriptUrl = PublicUrls.ForRequest(Context, Model.StoreId, Url.Action("Asset", "DigitalDownloadsAssets", new { storeId = Model.StoreId, fileName = "makepay-media.js" })!);
    var analytics = new DigitalAnalyticsViewModel { StoreId = Model.StoreId, Settings = Model.Settings, PageType = "purchase" };
    var purchaseAnalytics = DigitalAnalyticsBuilder.Checkout(Model.Checkout, purchase: true);
    var analyticsDedupeId = DigitalAnalyticsBuilder.AnalyticsTransactionId(Model.Checkout);
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="referrer" content="no-referrer">
    @if(waiting){<meta http-equiv="refresh" content="5">}
    <title>Your purchase · @Model.Settings.StorefrontTitle</title>
    <partial name="~/Views/DigitalDownloads/Public/_Theme.cshtml" model="Model.Settings" />
    <partial name="~/Views/DigitalDownloads/Public/_AnalyticsHead.cshtml" model="analytics" />
</head>
<body class="dp-public">
<main class="dp-shell">
    <header class="dp-topbar">
        <a class="dp-topbar-brand" asp-action="Storefront" asp-route-storeId="@Model.StoreId">@Model.Settings.StorefrontTitle</a>
        <nav class="dp-topnav"><a class="dp-nav-link" asp-action="Storefront" asp-route-storeId="@Model.StoreId">Browse</a><a class="dp-nav-link is-active" asp-action="Account" asp-route-storeId="@Model.StoreId">Purchases</a></nav>
    </header>
    <section class="dp-success">
        @if(Model.Checkout.Status == DigitalCheckoutStatus.Paid)
        {
            <div class="dp-success-mark"><img src="~/imlegacy/checkmark.svg" alt=""></div>
            <p class="dp-eyebrow">Order complete</p><h1>@Model.Settings.ConfirmationTitle</h1><p class="dp-success-lead">@Model.Settings.ConfirmationMessage</p>
            @if(!Model.CustomerAuthenticated){<div class="dp-auth-note">Use <strong>@Model.Checkout.BuyerEmail</strong> to sign in anytime and recover this purchase from your private library.</div>}
            <div class="dp-library-grid">
                @if(Model.Downloads.Count>0){<section class="dp-library-section"><header><h2>Digital products</h2></header>@foreach(var item in Model.Downloads){<partial name="~/Views/DigitalDownloads/Public/_DigitalLibraryItem.cshtml" model="item" />}</section>}
                @if(Model.Licenses.Count>0){<section class="dp-library-section"><header><h2>License keys</h2></header>@foreach(var item in Model.Licenses){<article class="dp-library-item"><div class="dp-library-product-head"><div><div class="dp-library-product-type">Software license</div><h3>@item.Product.Name</h3></div><span class="dp-status paid">@item.License.Status</span></div><p class="dp-library-meta">@($"{item.License.Activations.Count} of {item.License.MaxActivations} activations{(item.License.ExpiresAt is null ? " · Lifetime" : " · Expires " + item.License.ExpiresAt.Value.ToString("d MMM yyyy"))}")</p>@if(item.LicenseKey is not null){<input class="dp-key" value="@item.LicenseKey" readonly aria-label="License key for @item.Product.Name">}</article>}</section>}
            </div>
            <div class="dp-actions"><a class="dp-secondary" asp-action="Storefront" asp-route-storeId="@Model.StoreId">Keep shopping</a><a class="dp-primary" asp-action="Account" asp-route-storeId="@Model.StoreId">Open purchase library</a></div>
        }
        else if(Model.Checkout.Status == DigitalCheckoutStatus.Cancelled)
        {
            <p class="dp-eyebrow">Invoice closed</p><h1>Payment was not completed</h1><p class="dp-success-lead">This invoice can no longer be paid. Return to the shop and start a new checkout when you are ready.</p><div class="dp-actions"><a class="dp-primary" asp-action="Storefront" asp-route-storeId="@Model.StoreId">Return to shop</a></div>
        }
        else
        {
            <div class="dp-spinner"></div><p class="dp-eyebrow">Confirming payment</p><h1>Preparing your purchase</h1><p class="dp-success-lead">BTCPay is confirming the invoice and securely issuing your digital products and license keys. This page refreshes automatically.</p><p class="dp-library-meta">Order @Model.Checkout.Id[..8]</p>
        }
    </section>
    <partial name="~/Views/DigitalDownloads/Public/_Footer.cshtml" model="Model.Settings" />
</main>
@if (Model.Checkout.Status == DigitalCheckoutStatus.Paid)
{
    <script type="application/json" data-makepay-analytics-load="purchase" data-makepay-analytics-once="@analyticsDedupeId">@Html.Raw(JsonSerializer.Serialize(purchaseAnalytics))</script>
}
<partial name="~/Views/DigitalDownloads/Public/_AnalyticsConsent.cshtml" model="analytics" />
<script src="@mediaScriptUrl" defer></script>
</body>
</html>
