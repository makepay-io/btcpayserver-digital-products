@model OrderViewModel
@{ Layout = null; }
<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><meta http-equiv="refresh" content="@((Model.Order.Status == DigitalOrderStatus.Pending) ? "10" : "")"><title>Your order</title><partial name="~/Views/DigitalDownloads/Public/_Theme.cshtml" model="Model.Settings" /></head><body class="dp-public"><main class="dp-auth-shell"><section class="dp-auth-card"><a class="dp-topbar-brand" href="javascript:history.back()">@Model.Settings.StorefrontTitle</a><p class="dp-eyebrow">Protected delivery</p><h1>@Model.Product.Name</h1>
@if(Model.Order.Status == DigitalOrderStatus.Paid && Model.DownloadUrl is not null){<p>Payment received. Your protected download is ready.</p><p><a class="dp-primary" style="width:100%" href="@Model.DownloadUrl">Download file</a></p><p class="dp-auth-help">@Model.Order.DownloadCount of @Model.Order.MaxDownloads downloads used. Link expires @Model.Order.ExpiresAt?.ToString("u").</p>}
else if(Model.Order.Status == DigitalOrderStatus.Revoked){<div class="dp-alert">This download has been revoked. Contact the merchant if you need help.</div>}
else {<div class="dp-spinner"></div><p>We are waiting for payment confirmation. This page refreshes automatically.</p><p class="dp-auth-help">Order @Model.Order.Id[..8]</p>}
</section></main></body></html>
