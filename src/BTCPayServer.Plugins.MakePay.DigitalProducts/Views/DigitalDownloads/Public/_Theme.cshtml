@model DigitalDownloadsSettings
@{
    var font = Model.FontStyle switch
    {
        DigitalStoreFontStyle.Rounded => "ui-rounded, 'Arial Rounded MT Bold', system-ui, sans-serif",
        DigitalStoreFontStyle.Editorial => "Georgia, 'Times New Roman', serif",
        DigitalStoreFontStyle.Grotesk => "Arial, Helvetica, sans-serif",
        DigitalStoreFontStyle.System => "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
        _ => "'Helvetica Neue', Inter, ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
    };
}
<style>
    :root{--dp-accent:@Model.AccentColor;--dp-accent-text:@Model.AccentTextColor;--dp-brand-text:@Model.BrandTextColor;--dp-page:@Model.PageBackgroundColor;--dp-surface:@Model.SurfaceColor;--dp-text:@Model.TextColor;--dp-muted:@Model.MutedColor;--dp-soft:@Model.SoftColor;--dp-brand-width:@(Model.BrandPanelWidth)%;--dp-font:@Html.Raw(font);--dp-border:#e4e7ec;--dp-danger:#b42318;--dp-success:#067647}
    *{box-sizing:border-box}html{scroll-behavior:smooth}body.dp-public{margin:0;background:var(--dp-page);color:var(--dp-text);font:16px/1.5 var(--dp-font);-webkit-font-smoothing:antialiased}body.dp-public button,body.dp-public input,body.dp-public select,body.dp-public textarea{font:inherit}body.dp-public a{color:var(--dp-accent)}
    .dp-brand-shell{display:grid;grid-template-columns:minmax(390px,var(--dp-brand-width)) minmax(560px,1fr);min-height:100vh}.dp-brand-panel{position:sticky;top:0;height:100vh;overflow:hidden;background:var(--dp-accent);color:var(--dp-brand-text);isolation:isolate}.dp-brand-image{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:-2}.dp-brand-scrim{position:absolute;inset:0;background:rgba(0,0,0,.3);z-index:-1}.dp-brand-content{height:100%;display:flex;flex-direction:column;justify-content:flex-end;padding:clamp(36px,5vw,78px)}.dp-brand-logo{max-width:220px;max-height:70px;object-fit:contain;object-position:left center;margin-bottom:34px}.dp-brand-wordmark{font-size:1.15rem;font-weight:850;letter-spacing:.03em;text-transform:uppercase;margin-bottom:34px}.dp-eyebrow{font-size:.76rem;font-weight:850;letter-spacing:.16em;text-transform:uppercase;margin:0 0 14px}.dp-brand-headline{font-size:clamp(2.8rem,5.4vw,6.6rem);line-height:.92;letter-spacing:-.055em;text-transform:uppercase;margin:0;max-width:10ch}.dp-brand-subheadline{font-size:1.03rem;max-width:40rem;margin:24px 0 0;opacity:.9}.dp-brand-meta{margin-top:clamp(32px,5vh,66px);font-size:.92rem;font-weight:750;text-transform:uppercase;letter-spacing:.04em}
    .dp-shop{min-width:0;padding:28px clamp(26px,4vw,64px) 54px}.dp-shop-inner{max-width:980px;margin:0 auto}.dp-topbar{display:flex;align-items:center;justify-content:space-between;gap:18px;margin-bottom:42px}.dp-topbar-brand{font-size:.88rem;font-weight:850;letter-spacing:.05em;text-transform:uppercase;color:var(--dp-text);text-decoration:none}.dp-topnav{display:flex;align-items:center;gap:8px;flex-wrap:wrap;justify-content:flex-end}.dp-nav-link{display:inline-flex;align-items:center;min-height:40px;padding:8px 13px;border:1px solid transparent;border-radius:9px;color:var(--dp-text)!important;text-decoration:none;font-size:.86rem;font-weight:750}.dp-nav-link:hover,.dp-nav-link.is-active{border-color:var(--dp-border);background:var(--dp-soft)}.dp-nav-link.cart{border-color:var(--dp-accent);background:var(--dp-accent);color:var(--dp-accent-text)!important}
    .dp-page-title{font-size:clamp(2rem,3.2vw,3.35rem);line-height:1.02;letter-spacing:-.04em;text-transform:uppercase;margin:0}.dp-page-subtitle{margin:9px 0 28px;color:var(--dp-muted);font-weight:600;max-width:700px}.dp-filter{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:28px}.dp-filter a{display:inline-flex;align-items:center;min-height:38px;border:1px solid var(--dp-border);border-radius:999px;padding:7px 14px;color:var(--dp-text)!important;text-decoration:none;font-size:.83rem;font-weight:750;background:var(--dp-surface)}.dp-filter a:hover,.dp-filter a.is-active{border-color:var(--dp-accent);color:var(--dp-accent)!important;background:color-mix(in srgb,var(--dp-accent) 6%,var(--dp-surface))}
    .dp-product-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:18px}.dp-product-card{display:flex;flex-direction:column;min-width:0;border:1px solid var(--dp-border);border-radius:16px;background:var(--dp-surface);overflow:hidden}.dp-product-image{display:block;width:100%;aspect-ratio:16/9;object-fit:cover;border-bottom:1px solid var(--dp-border)}.dp-product-body{display:flex;flex-direction:column;flex:1;padding:22px}.dp-product-type{color:var(--dp-accent);font-size:.72rem;font-weight:850;letter-spacing:.1em;text-transform:uppercase;margin-bottom:8px}.dp-badge{display:inline-flex;width:max-content;max-width:100%;margin:0 0 10px;padding:4px 8px;border-radius:999px;background:color-mix(in srgb,var(--dp-accent) 10%,var(--dp-surface));color:var(--dp-accent);font-size:.7rem;font-weight:850;letter-spacing:.05em;text-transform:uppercase}.dp-product-card h2{font-size:1.2rem;line-height:1.25;letter-spacing:-.02em;margin:0 0 9px}.dp-product-description{display:-webkit-box;-webkit-box-orient:vertical;-webkit-line-clamp:3;overflow:hidden;color:var(--dp-muted);font-size:.92rem;margin:0 0 13px;white-space:pre-line}.dp-product-meta{color:var(--dp-muted);font-size:.78rem;margin-top:auto;padding-top:4px}.dp-product-buy{display:flex;align-items:end;justify-content:space-between;gap:14px;margin-top:19px;padding-top:17px;border-top:1px solid var(--dp-border)}.dp-price{font-size:1.18rem;font-weight:850;white-space:nowrap}.dp-old-price{display:block;color:var(--dp-muted);font-size:.76rem;font-weight:650;text-decoration:line-through}.dp-primary,.dp-secondary,.dp-danger-button{display:inline-flex;align-items:center;justify-content:center;min-height:46px;border-radius:10px;padding:11px 18px;text-decoration:none;font-weight:800;cursor:pointer}.dp-primary{border:1px solid var(--dp-accent);background:var(--dp-accent);color:var(--dp-accent-text)!important}.dp-secondary{border:1px solid var(--dp-border);background:var(--dp-surface);color:var(--dp-text)!important}.dp-danger-b