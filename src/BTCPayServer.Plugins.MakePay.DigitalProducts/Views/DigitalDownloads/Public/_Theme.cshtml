    .dp-footer{margin-top:46px;padding-top:24px;border-top:1px solid var(--dp-border);color:var(--dp-muted);font-size:.84rem}.dp-promotion{margin-top:14px;padding:14px 16px;border-radius:12px;background:var(--dp-soft);font-size:.82rem}.dp-promotion a{font-weight:800}
    .dp-shell{max-width:1160px;margin:0 auto;padding:28px 24px 54px}.dp-shell .dp-topbar{margin-bottom:54px}.dp-section-heading{font-size:clamp(1.9rem,4vw,3rem);line-height:1.05;letter-spacing:-.04em;margin:0 0 8px}.dp-section-copy{color:var(--dp-muted);margin:0 0 28px}.dp-card{border:1px solid var(--dp-border);border-radius:16px;background:var(--dp-surface);overflow:hidden}.dp-cart-head,.dp-cart-row{display:grid;grid-template-columns:minmax(0,1fr) 120px 110px 120px;gap:18px;align-items:center;padding:18px 24px}.dp-cart-head{background:var(--dp-soft);color:var(--dp-muted);font-size:.76rem;font-weight:850;text-transform:uppercase;letter-spacing:.06em}.dp-cart-row{border-top:1px solid var(--dp-border)}.dp-cart-row:first-of-type{border-top:0}.dp-cart-product{display:flex;align-items:center;gap:14px;min-width:0}.dp-cart-thumb{width:68px;height:54px;object-fit:cover;border-radius:8px;border:1px solid var(--dp-border)}.dp-cart-name{min-width:0}.dp-cart-name strong{display:block}.dp-cart-name span{display:block;color:var(--dp-muted);font-size:.8rem}.dp-qty-form{display:flex;align-items:center;gap:6px}.dp-qty{width:58px;border:1px solid #d0d5dd;border-radius:8px;background:var(--dp-surface);color:var(--dp-text);padding:8px}.dp-link-button{border:0;background:none;color:var(--dp-accent);padding:5px 0;font-weight:750;cursor:pointer}.dp-summary{margin-top:22px;margin-left:auto;max-width:440px;padding:22px 25px;border:1px solid var(--dp-border);border-radius:16px;background:var(--dp-soft)}.dp-summary-row{display:flex;justify-content:space-between;gap:18px;margin:8px 0}.dp-summary-row.total{border-top:1px dashed #d0d5dd;padding-top:15px;margin-top:15px;font-size:1.12rem;font-weight:850}.dp-actions{display:flex;justify-content:space-between;gap:14px;margin-top:26px}.dp-auth-note{margin-top:22px;padding:16px 18px;border:1px solid color-mix(in srgb,var(--dp-accent) 25%,var(--dp-border));border-radius:12px;background:color-mix(in srgb,var(--dp-accent) 6%,var(--dp-surface));color:var(--dp-accent);font-size:.88rem}
    .dp-auth-shell{min-height:100vh;display:grid;place-items:center;padding:28px;background:var(--dp-soft)}.dp-auth-card{width:min(100%,520px);border:1px solid var(--dp-border);border-radius:18px;background:var(--dp-surface);padding:34px;box-shadow:0 22px 60px rgba(16,24,40,.1)}.dp-auth-card .dp-topbar-brand{display:block;margin-bottom:34px}.dp-auth-card h1{font-size:2rem;line-height:1.1;letter-spacing:-.035em;margin:0 0 9px}.dp-auth-card>p{color:var(--dp-muted);margin:0 0 24px}.dp-field{display:flex;flex-direction:column;gap:7px;margin-bottom:16px}.dp-field label{font-size:.84rem;font-weight:750}.dp-input{width:100%;border:1px solid #d0d5dd;border-radius:10px;background:var(--dp-surface);color:var(--dp-text);padding:12px 14px;outline:none}.dp-input:focus{border-color:var(--dp-accent);box-shadow:0 0 0 3px color-mix(in srgb,var(--dp-accent) 15%,transparent)}.dp-code-input{text-align:center;font:800 1.4rem/1.2 ui-monospace,SFMono-Regular,Consolas,monospace;letter-spacing:.28em}.dp-alert{border:1px solid #fda29b;background:#fef3f2;color:var(--dp-danger);border-radius:10px;padding:12px 14px;margin-bottom:16px}.dp-auth-card .dp-primary{width:100%}.dp-auth-help{font-size:.8rem;color:var(--dp-muted);margin-top:18px!important;text-align:center}
