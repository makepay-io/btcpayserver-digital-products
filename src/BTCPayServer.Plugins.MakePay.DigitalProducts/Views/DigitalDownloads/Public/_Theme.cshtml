        DigitalStoreFontStyle.Rounded => "ui-rounded, 'Arial Rounded MT Bold', system-ui, sans-serif",
        DigitalStoreFontStyle.Editorial => "Georgia, 'Times New Roman', serif",
        DigitalStoreFontStyle.Grotesk => "Arial, Helvetica, sans-serif",
        DigitalStoreFontStyle.System => "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
        _ => "'Helvetica Neue', Inter, ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
    };
}
@if (faviconUrl is not null)
{
    <link rel="icon" href="@faviconUrl">
}
<style>
