    @@media(max-width:640px){.dp-brand-panel{height:400px}.dp-brand-headline{font-size:2.75rem}.dp-brand-logo{max-width:170px;margin-bottom:20px}.dp-brand-meta{margin-top:24px}.dp-shop{padding:20px 16px 38px}.dp-topbar{align-items:flex-start;margin-bottom:34px}.dp-topbar-brand{max-width:130px}.dp-product-grid{grid-template-columns:1fr}.dp-product-body{padding:20px}.dp-shell{padding:20px 16px 40px}.dp-shell .dp-topbar{margin-bottom:38px}.dp-cart-head{display:none}.dp-cart-row{grid-template-columns:minmax(0,1fr) 84px;padding:16px}.dp-cart-row>div:nth-child(2){display:none}.dp-cart-row>strong{display:none}.dp-summary{max-width:none}.dp-actions{flex-direction:column-reverse}.dp-actions>*{width:100%}.dp-auth-shell{padding:16px}.dp-auth-card{padding:26px 20px}.dp-payment-card{padding:34px 20px}.dp-order-row{grid-template-columns:1fr auto}.dp-order-row>*:nth-child(2){display:none}}
    .dp-cart-head,.dp-cart-row{grid-template-columns:minmax(0,1fr) minmax(104px,120px) minmax(164px,180px) minmax(120px,136px);gap:20px}.dp-cart-row>strong{justify-self:end;white-space:nowrap}.dp-qty-form{display:grid;grid-template-columns:minmax(52px,64px) minmax(0,1fr);gap:8px;min-width:0}.dp-qty-form .dp-secondary{min-width:0;padding-inline:12px}.dp-qty-form>span{align-self:center}
    @@media(max-width:880px){.dp-cart-head,.dp-cart-row{grid-template-columns:minmax(0,1fr) minmax(154px,170px) minmax(108px,120px)}}
    @@media(max-width:640px){.dp-cart-row{grid-template-columns:1fr}.dp-cart-row>form.dp-qty-form{display:grid;width:min(100%,200px);grid-template-columns:64px minmax(0,1fr);margin-top:10px}.dp-cart-row>strong{display:block;justify-self:start;margin-top:8px}.dp-cart-row>div:nth-child(2){display:none}}
</style>
