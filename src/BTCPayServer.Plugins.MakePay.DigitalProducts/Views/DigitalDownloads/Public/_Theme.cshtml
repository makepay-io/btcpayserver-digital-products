    .dp-success{max-width:980px;margin:0 auto;padding:36px 0}.dp-success-mark{display:grid;place-items:center;width:64px;height:64px;border-radius:50%;background:#dcfae6;margin-bottom:24px}.dp-success-mark img{display:block;width:32px;height:25px}.dp-success h1{font-size:clamp(2.3rem,5vw,4rem);line-height:1;letter-spacing:-.045em;margin:0 0 14px}.dp-success-lead{font-size:1.08rem;color:var(--dp-muted);max-width:700px}.dp-library-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:34px}.dp-library-section{border:1px solid var(--dp-border);border-radius:16px;background:var(--dp-surface);overflow:hidden}.dp-library-section>header{padding:20px 22px;background:var(--dp-soft);border-bottom:1px solid var(--dp-border)}.dp-library-section>header h2{font-size:1.1rem;margin:0}.dp-library-item{padding:20px 22px;border-top:1px solid var(--dp-border)}.dp-library-item:first-of-type{border-top:0}.dp-library-item h3{font-size:1rem;margin:0 0 4px}.dp-library-meta{color:var(--dp-muted);font-size:.82rem;margin:0 0 14px}.dp-key{width:100%;border:1px solid var(--dp-border);border-radius:9px;background:var(--dp-soft);color:var(--dp-text);padding:10px 12px;font:700 .82rem ui-monospace,SFMono-Regular,Consolas,monospace}.dp-order-list{margin-top:22px}.dp-order-row{display:grid;grid-template-columns:minmax(0,1fr) 130px 110px;gap:16px;align-items:center;padding:17px 20px;border-top:1px solid var(--dp-border)}.dp-order-row:first-child{border-top:0}.dp-status{display:inline-flex;width:max-content;border-radius:999px;padding:4px 8px;background:var(--dp-soft);color:var(--dp-muted);font-size:.72rem;font-weight:800;text-transform:uppercase}.dp-status.paid{background:#dcfae6;color:var(--dp-success)}.dp-spinner{width:46px;height:46px;border:4px solid var(--dp-border);border-top-color:var(--dp-accent);border-radius:50%;margin:0 auto 20px;animation:dp-spin .8s linear infinite}@@keyframes dp-spin{to{transform:rotate(360deg)}}
    @@media(max-width:1100px){.dp-brand-shell{grid-template-columns:minmax(360px,43%) minmax(520px,1fr)}.dp-brand-headline{font-size:clamp(2.7rem,5vw,5rem)}.dp-shop{padding-left:34px;padding-right:34px}}
