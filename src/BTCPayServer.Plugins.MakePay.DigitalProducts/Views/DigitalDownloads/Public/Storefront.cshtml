@model StorefrontViewModel
@{ Layout = null; }
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>@Model.Settings.StorefrontTitle</title>
    <style>
        :root{--accent:@Model.Settings.AccentColor}*{box-sizing:border-box}body{margin:0;background:#f5f7fb;color:#152033;font:16px/1.5 system-ui,-apple-system,sans-serif}.shell{max-width:1120px;margin:auto;padding:40px 24px}.hero{text-align:center;padding:32px 0 36px}.logo{max-height:64px;max-width:220px}.hero h1{font-size:clamp(2rem,5vw,4rem);margin:.5rem 0}.hero p{color:#64748b;font-size:1.15rem}.catalog-nav{display:flex;justify-content:center;gap:8px;flex-wrap:wrap;margin-bottom:34px}.catalog-nav a{color:#334155;text-decoration:none;background:#fff;border:1px solid #dce3ed;padding:9px 16px;border-radius:999px;font-weight:700}.catalog-nav a:hover{border-color:var(--accent);color:var(--accent)}.section{scroll-margin-top:24px;margin-top:34px}.section-head{display:flex;justify-content:space-between;align-items:end;gap:20px;margin-bottom:18px}.section-head h2{margin:0;font-size:1.7rem}.section-head p{margin:0;color:#64748b}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:24px}.card{background:white;border:1px solid #e5eaf2;border-radius:20px;overflow:hidden;box-shadow:0 12px 35px #1725540d}.cover{aspect-ratio:16/10;width:100%;object-fit:cover;background:#e8edf5}.content{padding:24px}.content h3{margin-top:0}.meta{color:#64748b;font-size:.92rem}.price{font-size:1.4rem;font-weight:750;margin:16px 0}.buy{display:flex;gap:8px}.buy input{min-width:0;flex:1;padding:11px;border:1px solid #ccd4e0;border-radius:10px}.buy button{border:0;background:var(--accent);color:white;padding:11px 16px;border-radius:10px;font-weight:700;cursor:pointer}.empty{padding:30px;border:1px dashed #cbd5e1;border-radius:18px;color:#64748b;text-align:center;background:#fff}.promo{text-align:center;color:#64748b;font-size:.85rem;margin-top:48px}.promo a{color:var(--accent)}@@media(max-width:560px){.shell{padding:24px 16px}.hero{padding-top:18px}.section-head{display:block}.buy{flex-direction:column}.buy button{width:100%}}
    </style>
</head>
<body>
<main class="shell">
    <header class="hero">
        @if (Model.Settings.LogoUrl is not null) { <img class="logo" src="@Model.Settings.LogoUrl" alt=""> }
        <h1>@Model.Settings.StorefrontTitle</h1>
        <p>@Model.Settings.StorefrontDescription</p>
    </header>
    <nav class="catalog-nav" aria-label="Product types">
        <a href="#downloads">Digital downloads (@Model.Products.Count)</a>
        <a href="#licenses">Software licenses (@Model.LicenseProducts.Count)</a>
    </nav>
    <section id="downloads" class="section">
        <div class="section-head"><div><h2>Digital downloads</h2><p>Protected files delivered after BTCPay confirms payment.</p></div></div>
        @if (Model.Products.Count == 0) { <div class="empty">No download products are published yet.</div> }
        else {
            <div class="grid">
                @foreach (var product in Model.Products) {
                    <article class="card">
                        @if (product.ImageUrl is not null) { <img class="cover" src="@product.ImageUrl" alt=""> }
                        <div class="content"><h3>@product.Name</h3><p>@product.Description</p><div class="meta">Protected, expiring delivery link</div><div class="price">@product.Price.ToString("0.00") @Model.Settings.Currency</div><form class="buy" method="post" asp-controller="DigitalDownloadsPublic" asp-action="Buy" asp-route-storeId="@Model.StoreId" asp-route-productId="@product.Id"><input type="email" name="email" required autocomplete="email" placeholder="Email for delivery"><button>Buy download</button></form></div>
                    </article>
                }
            </div>
        }
    </section>
    <section id="licenses" class="section">
        <div class="section-head"><div><h2>Software licenses</h2><p>Generated serial keys with signed activation and verification APIs.</p></div></div>
        @if (Model.LicenseProducts.Count == 0) { <div class="empty">No license products are published yet.</div> }
        else {
            <div class="grid">
                @foreach (var product in Model.LicenseProducts) {
                    <article class="card"><div class="content"><h3>@product.Name</h3><p>@product.Description</p><div class="meta">@product.MaxActivations activation(s) · @(product.DurationDays is null ? "Lifetime" : product.DurationDays + " days")</div><div class="price">@product.Price.ToString("0.00") @Model.LicenseSettings.Currency</div><form class="buy" method="post" asp-controller="LicenseStorefront" asp-action="Buy" asp-route-storeId="@Model.StoreId" asp-route-productId="@product.Id"><input type="email" name="email" required autocomplete="email" placeholder="Email for license delivery"><button>Buy license</button></form></div></article>
                }
            </div>
        }
    </section>
    @if (Model.Settings.ShowMakePayPromotion) { <footer class="promo">@Model.Settings.PromotionText <a href="https://makepay.io" rel="noopener">makepay.io</a></footer> }
</main>
</body>
</html>
