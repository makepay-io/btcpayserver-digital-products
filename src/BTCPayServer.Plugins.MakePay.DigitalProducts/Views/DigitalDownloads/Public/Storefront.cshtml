@model StorefrontViewModel
@{ Layout = null; var type = Context.Request.Query["type"].ToString(); var returnUrl = Context.Request.Path.ToString() + Context.Request.QueryString.ToString(); }
<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>@Model.Settings.StorefrontTitle</title><partial name="~/Views/DigitalDownloads/Public/_Theme.cshtml" model="Model.Settings" /></head>
<body class="dp-public">
<main class="dp-brand-shell">
    <aside class="dp-brand-panel">
        @if(Model.Settings.HeroImageUrl is not null){<img class="dp-brand-image" src="@Model.Settings.HeroImageUrl" alt=""><div class="dp-brand-scrim"></div>}
        <div class="dp-brand-content">
            @if(Model.Settings.LogoUrl is not null){<img class="dp-brand-logo" src="@Model.Settings.LogoUrl" alt="@Model.Settings.StorefrontTitle">}else{<div class="dp-brand-wordmark">@Model.Settings.StorefrontTitle</div>}
            <p class="dp-eyebrow">@Model.Settings.HeroEyebrow</p><h1 class="dp-brand-headline">@Model.Settings.HeroHeadline</h1><p class="dp-brand-subheadline">@Model.Settings.HeroSubheadline</p><div class="dp-brand-meta">Protected delivery · Direct BTCPay checkout</div>
        </div>
    </aside>
    <section class="dp-shop"><div class="dp-shop-inner">
        <header class="dp-topbar"><a class="dp-topbar-brand" asp-action="Storefront" asp-route-storeId="@Model.StoreId">@Model.Settings.StorefrontTitle</a><nav class="dp-topnav" aria-label="Store navigation"><a class="dp-nav-link" asp-action="Storefront" asp-route-storeId="@Model.StoreId">Browse</a><a class="dp-nav-link" asp-action="Account" asp-route-storeId="@Model.StoreId">@(Model.CustomerEmail is null ? "Sign in" : "Purchases")</a><a class="dp-nav-link cart" asp-action="CartPage" asp-route-storeId="@Model.StoreId">Cart · @Model.CartCount</a></nav></header>
        <p class="dp-eyebrow">Digital storefront</p><h2 class="dp-page-title">@Model.Settings.CatalogTitle</h2><p class="dp-page-subtitle">@Model.Settings.CatalogSubtitle</p>
        <nav class="dp-filter" aria-label="Product filters"><a class="@(string.IsNullOrEmpty(type)?"is-active":"")" asp-action="Storefront" asp-route-storeId="@Model.StoreId">All products</a><a class="@(type=="downloads"?"is-active":"")" asp-action="Storefront" asp-route-storeId="@Model.StoreId" asp-route-type="downloads">Downloads</a><a class="@(type=="licenses"?"is-active":"")" asp-action="Storefront" asp-route-storeId="@Model.StoreId" asp-route-type="licenses">Licenses</a></nav>
        @if(Model.Catalog.Count==0){<div class="dp-empty">No products are published in this category yet.</div>}else{<div class="dp-product-grid">@foreach(var product in Model.Catalog){<article class="dp-product-card">@if(product.ImageUrl is not null){<img class="dp-product-image" src="@product.ImageUrl" alt="">}<div class="dp-product-body"><div class="dp-product-type">@(product.Kind==DigitalProductKind.Download?"Digital download":"Software license")</div>@if(product.Badge is not null){<span class="dp-badge">@product.Badge</span>}<h2>@product.Name</h2><p class="dp-product-description">@product.Description</p><div class="dp-product-meta">@product.Meta</div><div class="dp-product-buy"><div>@if(product.CompareAtPrice is not null){<span class="dp-old-price">@product.CompareAtPrice.Value.ToString("0.00") @Model.Settings.Currency</span>}<span class="dp-price">@product.Price.ToString("0.00") @Model.Settings.Currency</span></div><form method="post" asp-action="AddToCart" asp-route-storeId="@Model.StoreId"><input type="hidden" name="kind" value="@product.Kind"><input type="hidden" name="productId" value="@product.Id"><input type="hidden" name="quantity" value="1"><input type="hidden" name="returnUrl" value="@returnUrl"><button class="dp-primary" type="submit">Add to cart</button></form></div></div></article>}</div>}
        <partial name="~/Views/DigitalDownloads/Public/_Footer.cshtml" model="Model.Settings" />
    </div></section>
</main></body></html>
