@model StorefrontViewModel
@{
    Layout = null;
    var type = Context.Request.Query["type"].ToString();
    var returnUrl = Context.Request.Path.ToString() + Context.Request.QueryString.ToString();
    var heroUrl = Model.Settings.HeroImageUrl ?? Url.Action("HeroAsset", "DigitalDownloadsPublic", new { storeId = Model.StoreId });
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
    <title>@Model.Settings.StorefrontTitle</title>
    <partial name="~/Views/DigitalDownloads/Public/_Theme.cshtml" model="Model.Settings" />
    <style>
        .dp-market{min-height:100vh;background:var(--dp-page)}.dp-market-width{width:min(100% - 40px,1380px);margin-inline:auto}
        .dp-market-promo{min-height:38px;display:grid;place-items:center;padding:8px 20px;background:var(--dp-accent);color:var(--dp-accent-text);font-size:.8rem;font-weight:750;text-align:center}
        .dp-market-header{border-bottom:1px solid var(--dp-border);background:var(--dp-surface)}.dp-market-header .dp-market-width{min-height:72px;display:grid;grid-template-columns:minmax(230px,1fr) auto minmax(230px,1fr);align-items:center;gap:24px}
        .dp-market-brand{display:flex;align-items:center;gap:12px;color:var(--dp-accent)!important;text-decoration:none;font-size:.88rem;font-weight:900;letter-spacing:.025em;text-transform:uppercase}.dp-market-brand img{display:block;max-width:190px;max-height:40px;object-fit:contain;object-position:left center}
        .dp-market-nav,.dp-market-account{display:flex;align-items:center;gap:28px}.dp-market-account{justify-content:flex-end}.dp-market-nav a,.dp-market-account>a:not(.dp-primary){color:var(--dp-text)!important;text-decoration:none;font-size:.84rem;font-weight:750}.dp-market-nav a:hover,.dp-market-account>a:not(.dp-primary):hover{color:var(--dp-accent)!important}.dp-market-cart{min-height:42px;padding:9px 15px;border-radius:9px;box-shadow:0 7px 18px color-mix(in srgb,var(--dp-accent) 18%,transparent)}
        .dp-market-main{padding:22px 0 34px}.dp-market-hero{display:grid;grid-template-columns:minmax(0,.95fr) minmax(360px,1.05fr);align-items:center;min-height:300px;overflow:hidden;border:1px solid #edf0f5;border-radius:15px;background:linear-gradient(100deg,#f7f8fb,#f4f6fa)}.dp-market-hero-copy{padding:38px 42px}.dp-market-hero-copy .dp-eyebrow{color:var(--dp-accent);margin-bottom:14px}.dp-market-hero h1{max-width:19ch;margin:0;font-size:clamp(2.2rem,3.1vw,3rem);line-height:.98;letter-spacing:-.048em;text-transform:uppercase}.dp-market-hero p:not(.dp-eyebrow){max-width:500px;margin:18px 0 24px;color:var(--dp-muted);font-size:1.02rem}.dp-market-hero-art{height:100%;min-height:300px;display:grid;place-items:center;padding:18px 30px}.dp-market-hero-art img{display:block;width:100%;max-width:650px;max-height:290px;object-fit:contain}
        .dp-market-catalog{padding-top:24px}.dp-market-catalog-head{display:flex;justify-content:space-between;align-items:end;gap:22px;margin-bottom:14px}.dp-market-catalog h2{margin:0;font-size:1.6rem;letter-spacing:-.035em}.dp-market-view-all{text-decoration:none;font-size:.84rem;font-weight:800}.dp-market-view-all span{margin-left:9px}.dp-market-catalog .dp-filter{margin:10px 0 16px}
        .dp-market .dp-product-grid{grid-template-columns:repeat(3,minmax(0,1fr));gap:18px}.dp-market .dp-product-card{display:grid;grid-template-columns:132px minmax(0,1fr);min-height:230px;padding:16px;overflow:visible}.dp-market .dp-product-image{width:132px;height:172px;align-self:start;border:0;border-radius:8px;box-shadow:0 10px 24px rgba(16,24,40,.13);object-fit:cover}.dp-market .dp-product-body{padding:4px 0 0 18px}.dp-market .dp-product-card h3{font-size:1.08rem;line-height:1.2;letter-spacing:-.02em;margin:0 0 7px}.dp-market .dp-product-description{font-size:.85rem;-webkit-line-clamp:3;margin-bottom:10px}.dp-market .dp-product-buy{grid-column:1/-1;margin:14px 0 0;padding-top:13px}.dp-market .dp-product-buy form{margin-left:auto}.dp-market .dp-primary{min-height:42px;padding:9px 16px}.dp-market .dp-price{font-size:1rem}
        .dp-market-footer{margin-top:0;padding:30px 0 18px;background:#0d1b32;color:#dbe4f2}.dp-market-footer a{color:#a9c4ff}.dp-market-footer-grid{display:grid;grid-template-columns:1.35fr .8fr .8fr 1.15fr;gap:36px}.dp-market-footer h2,.dp-market-footer h3{color:#fff;text-transform:uppercase;letter-spacing:.08em}.dp-market-footer h2{font-size:.82rem;color:#6f9cff}.dp-market-footer h3{font-size:.73rem;margin:0 0 16px}.dp-market-footer p,.dp-market-footer li,.dp-market-footer a{font-size:.82rem}.dp-market-footer ul{list-style:none;padding:0;margin:0}.dp-market-footer li{margin:9px 0}.dp-market-footer-bottom{display:flex;justify-content:space-between;gap:24px;margin-top:24px;padding-top:18px;border-top:1px solid rgba(255,255,255,.12);color:#aebbd0;font-size:.75rem}
        @@media(max-width:1100px){.dp-market .dp-product-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.dp-market-header .dp-market-width{grid-template-columns:1fr auto}.dp-market-nav{display:none}.dp-market-footer-grid{grid-template-columns:1.3fr 1fr 1fr}.dp-market-footer-grid>div:last-child{grid-column:1/-1}}
        @@media(max-width:760px){.dp-market-width{width:min(100% - 28px,1380px)}.dp-market-header .dp-market-width{min-height:66px;grid-template-columns:minmax(0,1fr) auto;gap:14px}.dp-market-account{gap:10px}.dp-market-account>a:not(.dp-market-cart){display:none}.dp-market-brand{font-size:.72rem}.dp-market-brand img{max-width:150px}.dp-market-hero{grid-template-columns:1fr}.dp-market-hero-copy{padding:32px 24px 20px}.dp-market-hero h1{font-size:2.55rem}.dp-market-hero-art{min-height:210px;padding:0 20px 20px}.dp-market-hero-art img{max-height:220px}.dp-market .dp-product-grid{grid-template-columns:1fr}.dp-market-catalog-head{align-items:start}.dp-market-view-all{display:none}.dp-market-footer-grid{grid-template-columns:1fr 1fr}.dp-market-footer-grid>div:first-child,.dp-market-footer-grid>div:last-child{grid-column:1/-1}.dp-market-footer-bottom{flex-direction:column}}
        @@media(max-width:430px){.dp-market .dp-product-card{grid-template-columns:105px minmax(0,1fr)}.dp-market .dp-product-image{width:105px;height:140px}.dp-market .dp-product-body{padding-left:14px}.dp-market .dp-product-buy{align-items:center}.dp-market .dp-primary{padding-inline:12px}.dp-market-footer-grid{grid-template-columns:1fr}.dp-market-footer-grid>div{grid-column:auto!important}}
    </style>
</head>
<body class="dp-public">
<div class="dp-market">
    <div class="dp-market-promo">Secure downloads and software licenses, paid directly with BTCPay Server.</div>
    <header class="dp-market-header"><div class="dp-market-width">
        <a class="dp-market-brand" asp-action="Storefront" asp-route-storeId="@Model.StoreId">@if(Model.Settings.LogoUrl is not null){<img src="@Model.Settings.LogoUrl" alt="@Model.Settings.StorefrontTitle">}else{@Model.Settings.StorefrontTitle}</a>
        <nav class="dp-market-nav" aria-label="Store navigation"><a asp-action="Storefront" asp-route-storeId="@Model.StoreId">Shop</a><a asp-action="Storefront" asp-route-storeId="@Model.StoreId" asp-route-type="downloads">Downloads</a><a asp-action="Storefront" asp-route-storeId="@Model.StoreId" asp-route-type="licenses">Licenses</a></nav>
        <nav class="dp-market-account" aria-label="Customer navigation"><a asp-action="Account" asp-route-storeId="@Model.StoreId">@(Model.CustomerEmail is null ? "Sign in" : "Purchases")</a><a class="dp-primary dp-market-cart" asp-action="CartPage" asp-route-storeId="@Model.StoreId">Cart · @Model.CartCount</a></nav>
    </div></header>
    <main class="dp-market-main"><div class="dp-market-width">
        <section class="dp-market-hero"><div class="dp-market-hero-copy"><p class="dp-eyebrow">@Model.Settings.HeroEyebrow</p><h1>@Model.Settings.HeroHeadline</h1><p>@Model.Settings.HeroSubheadline</p><a class="dp-primary" href="#products">Explore products</a></div><div class="dp-market-hero-art"><img src="@heroUrl" alt="" /></div></section>
        <section class="dp-market-catalog" id="products"><div class="dp-market-catalog-head"><div><h2>@Model.Settings.CatalogTitle</h2><nav class="dp-filter" aria-label="Product filters"><a class="@(string.IsNullOrEmpty(type)?"is-active":"")" asp-action="Storefront" asp-route-storeId="@Model.StoreId">All products</a><a class="@(type=="downloads"?"is-active":"")" asp-action="Storefront" asp-route-storeId="@Model.StoreId" asp-route-type="downloads">Downloads</a><a class="@(type=="licenses"?"is-active":"")" asp-action="Storefront" asp-route-storeId="@Model.StoreId" asp-route-type="licenses">Licenses</a></nav></div><a class="dp-market-view-all" asp-action="Storefront" asp-route-storeId="@Model.StoreId">View all products <span aria-hidden="true">→</span></a></div>
            @if(Model.Catalog.Count==0){<div class="dp-empty">No products are published in this category yet.</div>}else{<div class="dp-product-grid">@foreach(var product in Model.Catalog){var productImage=product.ImageUrl??Url.Action("ProductAsset","DigitalDownloadsPublic",new{storeId=Model.StoreId,kind=product.Kind==DigitalProductKind.License?"license":"download"});<article class="dp-product-card"><img class="dp-product-image" src="@productImage" alt=""><div class="dp-product-body"><div class="dp-product-type">@(product.Kind==DigitalProductKind.Download?"Digital download":"Software license")</div><h3>@product.Name</h3><p class="dp-product-description">@product.Description</p><div class="dp-product-meta">@product.Meta</div></div><div class="dp-product-buy"><div>@if(product.CompareAtPrice is not null){<span class="dp-old-price">@product.CompareAtPrice.Value.ToString("0.00") @Model.Settings.Currency</span>}<span class="dp-price">@product.Price.ToString("0.00") @Model.Settings.Currency</span></div><form method="post" asp-action="AddToCart" asp-route-storeId="@Model.StoreId" data-loading-title="Adding to cart…"><input type="hidden" name="kind" value="@product.Kind"><input type="hidden" name="productId" value="@product.Id"><input type="hidden" name="quantity" value="1"><input type="hidden" name="returnUrl" value="@returnUrl"><button class="dp-primary" type="submit">Add to cart</button></form></div></article>}</div>}
        </section>
    </div></main>
    <footer class="dp-market-footer"><div class="dp-market-width"><div class="dp-market-footer-grid"><div><h2>@Model.Settings.StorefrontTitle</h2><p>@Model.Settings.StorefrontDescription</p><p>Powered by MakePay.io</p></div><div><h3>Shop</h3><ul><li><a asp-action="Storefront" asp-route-storeId="@Model.StoreId">All products</a></li><li><a asp-action="Storefront" asp-route-storeId="@Model.StoreId" asp-route-type="downloads">Downloads</a></li><li><a asp-action="Storefront" asp-route-storeId="@Model.StoreId" asp-route-type="licenses">Licenses</a></li></ul></div><div><h3>Customer</h3><ul><li><a asp-action="Account" asp-route-storeId="@Model.StoreId">My downloads</a></li><li><a asp-action="Account" asp-route-storeId="@Model.StoreId">My licenses</a></li><li><a asp-action="Account" asp-route-storeId="@Model.StoreId">Sign in</a></li></ul></div><div><h3>Powered by BTCPay Server</h3><p>Open-source, self-hosted payments for a sovereign future.</p><a href="https://btcpayserver.org" rel="noreferrer">btcpayserver.org</a></div></div><div class="dp-market-footer-bottom"><span>© @DateTime.UtcNow.Year @Model.Settings.StorefrontTitle — accept 90+ currencies in a decentralized way with BTCPay Server.</span>@if(Model.Settings.ShowMakePayPromotion){<a href="https://makepay.io" rel="noreferrer">Enable multicurrency.</a>}</div></div></footer>
</div></body></html>
