@model StorefrontViewModel
@{
    Layout = null;
    var returnUrl = Context.Request.Path.ToString() + Context.Request.QueryString.ToString();
    var analytics = new DigitalAnalyticsViewModel { StoreId = Model.StoreId, Settings = Model.Settings, PageType = "storefront" };
    var activeCategory = Model.Categories.FirstOrDefault(category => category.Slug == Model.ActiveCategorySlug);
    var analyticsListId = activeCategory?.Slug ?? "all-products";
    var analyticsListName = activeCategory?.Name ?? Model.Settings.CatalogTitle;
    var catalogAnalytics = DigitalAnalyticsBuilder.Catalog(Model.Catalog, Model.Settings.Currency, analyticsListId, analyticsListName);
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
    <title>@Model.Settings.StorefrontTitle</title>
    <partial name="~/Views/DigitalDownloads/Public/_Theme.cshtml" model="Model.Settings" />
    <partial name="~/Views/DigitalDownloads/Public/_AnalyticsHead.cshtml" model="analytics" />
    <style>
        .dp-market{min-height:100vh;background:var(--dp-page)}.dp-market-width{width:min(100% - 40px,1380px);margin-inline:auto}
        .dp-market-promo{min-height:38px;display:grid;place-items:center;padding:8px 20px;background:var(--dp-accent);color:var(--dp-accent-text);font-size:.8rem;font-weight:750;text-align:center}
        .dp-market-header{border-bottom:1px solid var(--dp-border);background:var(--dp-surface)}.dp-market-header .dp-market-width{min-height:72px;display:grid;grid-template-columns:minmax(230px,1fr) auto minmax(230px,1fr);align-items:center;gap:24px}
        .dp-market-brand{display:flex;align-items:center;gap:12px;color:var(--dp-accent)!important;text-decoration:none;font-size:.88rem;font-weight:900;letter-spacing:.025em;text-transform:uppercase;min-width:0}.dp-market-brand img{display:block;width:min(var(--dp-logo-width),100%);height:var(--dp-logo-height);max-width:100%;object-fit:contain;object-position:left center}
        .dp-market-nav,.dp-market-account{display:flex;align-items:center;gap:28px}.dp-market-nav{justify-content:center}.dp-market-account{justify-content:flex-end}.dp-market-nav a,.dp-market-account>a:not(.dp-primary){color:var(--dp-text)!important;text-decoration:none;font-size:.84rem;font-weight:750}.dp-market-nav a:hover,.dp-market-nav a.is-active,.dp-market-account>a:not(.dp-primary):hover{color:var(--dp-accent)!important}.dp-market-cart{min-height:42px;padding:9px 15px;border-radius:9px;box-shadow:0 7px 18px color-mix(in srgb,var(--dp-accent) 18%,transparent)}
        .dp-market-main{padding:22px 0 34px}.dp-market-hero{position:relative;min-height:300px;overflow:hidden;border:1px solid #edf0f5;border-radius:15px;background:linear-gradient(100deg,#f7f8fb,#f4f6fa)}.dp-market-hero-slide{display:none;grid-template-columns:minmax(0,.95fr) minmax(360px,1.05fr);align-items:center;min-height:300px}.dp-market-hero-slide.is-active{display:grid}.dp-market-hero-copy{padding:38px 42px}.dp-market-hero-copy .dp-eyebrow{color:var(--dp-accent);margin-bottom:14px}.dp-market-hero h1{max-width:19ch;margin:0;font-size:clamp(2.2rem,3.1vw,3rem);line-height:.98;letter-spacing:-.048em;text-transform:uppercase;overflow-wrap:anywhere}.dp-market-hero p:not(.dp-eyebrow){max-width:500px;margin:18px 0 24px;color:var(--dp-muted);font-size:1.02rem}.dp-market-hero-art{height:100%;min-height:300px;display:grid;place-items:center;padding:18px 30px}.dp-market-hero-art img{display:block;width:100%;max-width:650px;max-height:290px;object-fit:contain}.dp-market-hero-controls{position:absolute;right:18px;bottom:16px;display:flex;align-items:center;gap:8px;padding:6px;border-radius:10px;background:color-mix(in srgb,var(--dp-surface) 88%,transparent);box-shadow:0 5px 18px rgba(16,24,40,.1)}.dp-market-hero-controls button{min-height:32px;border:1px solid var(--dp-border);border-radius:7px;background:var(--dp-surface);color:var(--dp-text);font:inherit;font-size:.73rem;font-weight:750;padding:5px 9px}.dp-market-hero-dots{display:flex;gap:6px;padding:0 3px}.dp-market-hero-dot{width:8px!important;min-height:8px!important;height:8px;padding:0!important;border:0!important;border-radius:50%!important;background:var(--dp-border)!important}.dp-market-hero-dot.is-active{background:var(--dp-accent)!important}
        .dp-market-catalog{padding-top:24px}.dp-market-catalog-head{display:flex;justify-content:space-between;align-items:end;gap:22px;margin-bottom:14px}.dp-market-catalog h2{margin:0;font-size:1.6rem;letter-spacing:-.035em}.dp-market-catalog-subtitle{max-width:640px;margin:5px 0 0;color:var(--dp-muted);font-size:.86rem}.dp-market-view-all{color:var(--dp-accent)!important;text-decoration:none;font-size:.84rem;font-weight:800}.dp-market-view-all span{margin-left:9px}.dp-market-catalog .dp-filter{margin:10px 0 16px}
        .dp-market .dp-product-grid{grid-template-columns:repeat(3,minmax(0,1fr));gap:18px}.dp-market .dp-product-card{display:grid;grid-template-columns:148px minmax(0,1fr);min-height:244px;padding:16px;overflow:visible;scroll-margin-top:100px}.dp-market .dp-product-media{display:block;align-self:start;border-radius:8px}.dp-market .dp-product-image{display:block;width:148px;height:190px;border:1px solid #e7ecf3;border-radius:8px;box-shadow:0 10px 24px rgba(16,24,40,.11);object-fit:contain;object-position:center;background:#071d45;image-rendering:auto}.dp-market .dp-product-body{padding:4px 0 0 18px;min-width:0}.dp-market-product-kicker{display:flex;align-items:center;justify-content:space-between;gap:8px}.dp-market-preview-badge{display:inline-flex;padding:3px 7px;border:1px solid color-mix(in srgb,var(--dp-accent) 28%,var(--dp-border));border-radius:999px;color:var(--dp-accent);font-size:.62rem;font-weight:850;letter-spacing:.04em;text-transform:uppercase;white-space:nowrap}.dp-market .dp-product-card h3{font-size:1.08rem;line-height:1.2;letter-spacing:-.02em;margin:0 0 7px;overflow-wrap:anywhere}.dp-market .dp-product-title{color:var(--dp-text)!important;text-decoration:none}.dp-market .dp-product-title:hover{color:var(--dp-accent)!important}.dp-market .dp-product-description{font-size:.85rem;-webkit-line-clamp:3;margin-bottom:10px}.dp-market .dp-product-buy{grid-column:1/-1;margin:14px 0 0;padding-top:13px}.dp-market .dp-product-buy form{margin-left:auto}.dp-market .dp-primary{min-height:42px;padding:9px 16px}.dp-market .dp-price{font-size:1rem}
        .dp-market-footer{margin-top:0;padding:32px 0 18px;background:#0d1b32;color:#dbe4f2}.dp-market-footer a{color:#dbe4f2!important;text-decoration-color:rgba(219,228,242,.45);text-underline-offset:3px}.dp-market-footer a:hover{color:#fff!important;text-decoration-color:#fff}.dp-market-footer-grid{display:grid;grid-template-columns:1.45fr .85fr .85fr;gap:52px}.dp-market-footer h2,.dp-market-footer h3{color:#fff;text-transform:uppercase;letter-spacing:.08em}.dp-market-footer h2{font-size:.82rem;color:#6f9cff}.dp-market-footer h3{font-size:.73rem;margin:0 0 16px}.dp-market-footer p,.dp-market-footer li,.dp-market-footer a{font-size:.82rem}.dp-market-footer ul{list-style:none;padding:0;margin:0}.dp-market-footer li{margin:9px 0}.dp-market-powered{margin-top:18px}.dp-market-powered>span{display:block;margin-bottom:12px;color:#aebbd0;font-size:.72rem;font-weight:750;letter-spacing:.05em;text-transform:uppercase}.dp-market-powered-logos{display:flex;align-items:center;gap:24px;min-height:38px}.dp-market-powered-logos a{display:inline-flex;align-items:center;justify-content:flex-start;min-height:38px;padding:0;border:0;border-radius:0;text-decoration:none}.dp-market-powered-logos img{display:block;width:126px;height:32px;object-fit:contain;object-position:left center}.dp-makepay-wordmark{color:#fff!important;font-size:1.2rem!important;font-weight:700;letter-spacing:-.025em;line-height:1;white-space:nowrap}.dp-market-footer-bottom{display:flex;justify-content:space-between;gap:24px;margin-top:24px;padding-top:18px;border-top:1px solid rgba(255,255,255,.12);color:#aebbd0;font-size:.75rem}.dp-market-footer-bottom a{font-weight:750}
        @@media(max-width:1100px){.dp-market .dp-product-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.dp-market-header .dp-market-width{grid-template-columns:1fr auto}.dp-market-nav{display:none}.dp-market-footer-grid{grid-template-columns:1.3fr 1fr 1fr}}
        @@media(max-width:760px){.dp-market-width{width:min(100% - 28px,1380px)}.dp-market-header .dp-market-width{min-height:66px;grid-template-columns:minmax(0,1fr) auto;gap:14px}.dp-market-account{gap:10px}.dp-market-account>a:not(.dp-market-cart){display:none}.dp-market-brand{font-size:.72rem}.dp-market-brand img{width:min(var(--dp-logo-width),150px);height:min(var(--dp-logo-height),44px)}.dp-market-hero-slide{grid-template-columns:1fr}.dp-market-hero-copy{padding:32px 24px 20px}.dp-market-hero h1{font-size:2.55rem}.dp-market-hero-art{min-height:210px;padding:0 20px 62px}.dp-market-hero-art img{max-height:220px}.dp-market-hero-controls{right:12px;bottom:12px}.dp-market .dp-product-grid{grid-template-columns:1fr}.dp-market-catalog-head{align-items:start}.dp-market-view-all{display:none}.dp-market-footer-grid{grid-template-columns:1fr 1fr}.dp-market-footer-grid>div:first-child{grid-column:1/-1}.dp-market-footer-bottom{flex-direction:column}}
        @@media(max-width:430px){.dp-market .dp-product-card{grid-template-columns:110px minmax(0,1fr)}.dp-market .dp-product-image{width:110px;height:144px}.dp-market .dp-product-body{padding-left:14px}.dp-market .dp-product-buy{align-items:center}.dp-market .dp-primary{padding-inline:12px}.dp-market-footer-grid{grid-template-columns:1fr}.dp-market-footer-grid>div{grid-column:auto!important}}
    </style>
</head>
<body class="dp-public">
<div class="dp-market">
    @if (!string.IsNullOrWhiteSpace(Model.Settings.StorefrontAnnouncement))
    {
        <div class="dp-market-promo">@Model.Settings.StorefrontAnnouncement</div>
    }
    <header class="dp-market-header"><div class="dp-market-width">
        <a class="dp-market-brand" asp-action="Storefront" asp-route-storeId="@Model.StoreId" style="--dp-logo-width:@(Model.Settings.LogoWidth)px;--dp-logo-height:@(Model.Settings.LogoHeight)px">@if(!string.IsNullOrWhiteSpace(Model.Settings.LogoUrl)){<img src="@Model.Settings.LogoUrl" alt="@Model.Settings.StorefrontTitle">}else{@Model.Settings.StorefrontTitle}</a>
        <nav class="dp-market-nav" aria-label="Store navigation"><a class="@(Model.ActiveCategorySlug is null ? "is-active" : "")" asp-action="Storefront" asp-route-storeId="@Model.StoreId">Shop</a>@foreach(var category in Model.Categories.Take(5)){<a class="@(Model.ActiveCategorySlug == category.Slug ? "is-active" : "")" asp-action="Storefront" asp-route-storeId="@Model.StoreId" asp-route-category="@category.Slug">@category.Name</a>}</nav>
        <nav class="dp-market-account" aria-label="Customer navigation"><a asp-action="Account" asp-route-storeId="@Model.StoreId">@(Model.CustomerEmail is null ? "Sign in" : "Purchases")</a><a class="dp-primary dp-market-cart" asp-action="CartPage" asp-route-storeId="@Model.StoreId">Cart · @Model.CartCount</a></nav>
    </div></header>
    <main class="dp-market-main"><div class="dp-market-width">
        @if (Model.HeroSlides.Count > 0)
        {
            <section class="dp-market-hero" data-hero data-delay="@(Model.Settings.HeroAutoAdvanceSeconds * 1000)" aria-label="Featured products">
                @for (var index = 0; index < Model.HeroSlides.Count; index++)
                {
                    var slide = Model.HeroSlides[index];
                    <article class="dp-market-hero-slide @(index == 0 ? "is-active" : "")" data-hero-slide aria-hidden="@(index == 0 ? "false" : "true")"><div class="dp-market-hero-copy"><p class="dp-eyebrow">@slide.Eyebrow</p><h1>@slide.Headline</h1><p>@slide.SupportingCopy</p><a class="dp-primary" href="@slide.LinkUrl">@slide.ButtonText</a></div><div class="dp-market-hero-art"><img src="@slide.ImageUrl" alt="" /></div></article>
                }
                @if (Model.HeroSlides.Count > 1)
                {
                    <div class="dp-market-hero-controls"><button type="button" data-hero-previous>Previous</button><div class="dp-market-hero-dots" aria-label="Choose hero slide">@for(var index=0;index<Model.HeroSlides.Count;index++){<button class="dp-market-hero-dot @(index==0?"is-active":"")" type="button" data-hero-dot="@index" aria-label="Show slide @(index+1)"></button>}</div><button type="button" data-hero-next>Next</button></div>
                }
            </section>
        }
        <section class="dp-market-catalog" id="products"><div class="dp-market-catalog-head"><div><h2>@Model.Settings.CatalogTitle</h2>@if(!string.IsNullOrWhiteSpace(Model.Settings.CatalogSubtitle)){<p class="dp-market-catalog-subtitle">@Model.Settings.CatalogSubtitle</p>}<nav class="dp-filter" aria-label="Product filters"><a class="@(Model.ActiveCategorySlug is null ? "is-active" : "")" asp-action="Storefront" asp-route-storeId="@Model.StoreId">All products</a>@foreach(var category in Model.Categories){<a class="@(Model.ActiveCategorySlug == category.Slug ? "is-active" : "")" asp-action="Storefront" asp-route-storeId="@Model.StoreId" asp-route-category="@category.Slug">@category.Name</a>}</nav></div>@if(Model.ActiveCategorySlug is not null){<a class="dp-market-view-all" asp-action="Storefront" asp-route-storeId="@Model.StoreId">View all products <span aria-hidden="true">→</span></a>}</div>
            @if(Model.Catalog.Count==0){<div class="dp-empty">No products are published in this category yet.</div>}else{<div class="dp-product-grid">@foreach(var product in Model.Catalog){var productImage=product.ImageUrl??PublicUrls.ForRequest(Context,Model.StoreId,Url.Action("ProductAsset","DigitalDownloadsPublic",new{storeId=Model.StoreId,kind=DigitalStorefrontBuilder.ProductAssetKind(product)})!);var productAnalytics=DigitalAnalyticsBuilder.Product(product,Model.Settings.Currency,listId:analyticsListId,listName:analyticsListName);var productAnalyticsJson=JsonSerializer.Serialize(productAnalytics);<article class="dp-product-card" id="@DigitalStorefrontBuilder.ProductAnchor(product)"><a class="dp-product-media" asp-action="Product" asp-route-storeId="@Model.StoreId" asp-route-kind="@DigitalStorefrontBuilder.ProductKindSegment(product)" asp-route-productId="@product.Slug" data-makepay-analytics-click="select_item" data-makepay-analytics-payload="@productAnalyticsJson"><img class="dp-product-image" src="@productImage" alt="@product.Name" width="600" height="800" loading="lazy" decoding="async"></a><div class="dp-product-body"><div class="dp-market-product-kicker"><div class="dp-product-type">@DigitalStorefrontBuilder.ProductTypeLabel(product)</div>@if(product.HasPreview){<span class="dp-market-preview-badge">Preview</span>}</div><h3><a class="dp-product-title" asp-action="Product" asp-route-storeId="@Model.StoreId" asp-route-kind="@DigitalStorefrontBuilder.ProductKindSegment(product)" asp-route-productId="@product.Slug" data-makepay-analytics-click="select_item" data-makepay-analytics-payload="@productAnalyticsJson">@product.Name</a></h3><p class="dp-product-description">@product.Description</p><div class="dp-product-meta">@product.Meta</div></div><div class="dp-product-buy"><div>@if(product.CompareAtPrice is not null){<span class="dp-old-price">@product.CompareAtPrice.Value.ToString("0.00") @Model.Settings.Currency</span>}<span class="dp-price">@product.Price.ToString("0.00") @Model.Settings.Currency</span></div><form method="post" asp-action="AddToCart" asp-route-storeId="@Model.StoreId" data-loading-title="Adding to cart…" data-makepay-analytics-form="add_to_cart" data-makepay-analytics-payload="@productAnalyticsJson"><input type="hidden" name="kind" value="@product.Kind"><input type="hidden" name="productId" value="@product.Id"><input type="hidden" name="quantity" value="1"><input type="hidden" name="returnUrl" value="@returnUrl"><button class="dp-primary" type="submit">Add to cart</button></form></div></article>}</div>}
        </section>
    </div></main>
    <footer class="dp-market-footer"><div class="dp-market-width"><div class="dp-market-footer-grid"><div><h2>@Model.Settings.StorefrontTitle</h2><p>@Model.Settings.StorefrontDescription</p><div class="dp-market-powered"><span>Powered by BTCPay &amp; MakePay.io</span><div class="dp-market-powered-logos"><a href="https://btcpayserver.org" rel="noreferrer" target="_blank" aria-label="Visit BTCPay Server"><img src="/img/btcpay-logo-white-txt.svg" alt="BTCPay Server"></a><a class="dp-makepay-wordmark" href="https://makepay.io" rel="noreferrer" target="_blank" aria-label="Visit MakePay.io">✦ MakePay</a></div></div></div><div><h3>Shop</h3><ul><li><a asp-action="Storefront" asp-route-storeId="@Model.StoreId">All products</a></li>@foreach(var category in Model.Categories){<li><a asp-action="Storefront" asp-route-storeId="@Model.StoreId" asp-route-category="@category.Slug">@category.Name</a></li>}</ul></div><div><h3>Customer</h3><ul><li><a asp-action="Account" asp-route-storeId="@Model.StoreId">My digital products</a></li><li><a asp-action="Account" asp-route-storeId="@Model.StoreId">My licenses</a></li><li><a asp-action="Account" asp-route-storeId="@Model.StoreId">Sign in</a></li></ul></div></div><div class="dp-market-footer-bottom"><span>© @DateTime.UtcNow.Year @Model.Settings.StorefrontTitle</span><a href="https://makepay.io" rel="noreferrer" target="_blank">@DigitalStorefrontBuilder.EnforcedPromotionText</a></div></div></footer>
</div>
<script type="application/json" data-makepay-analytics-load="view_item_list">@Html.Raw(JsonSerializer.Serialize(catalogAnalytics))</script>
<partial name="~/Views/DigitalDownloads/Public/_AnalyticsConsent.cshtml" model="analytics" />
@if (Model.HeroSlides.Count > 1)
{
<script>
(()=>{const root=document.querySelector('[data-hero]');if(!root)return;const slides=[...root.querySelectorAll('[data-hero-slide]')],dots=[...root.querySelectorAll('[data-hero-dot]')];let active=0,timer;const show=index=>{active=(index+slides.length)%slides.length;slides.forEach((slide,i)=>{const current=i===active;slide.classList.toggle('is-active',current);slide.setAttribute('aria-hidden',current?'false':'true')});dots.forEach((dot,i)=>dot.classList.toggle('is-active',i===active))};const stop=()=>clearInterval(timer);const start=()=>{stop();const delay=Number(root.dataset.delay);if(delay>0&&!matchMedia('(prefers-reduced-motion: reduce)').matches)timer=setInterval(()=>show(active+1),delay)};root.querySelector('[data-hero-previous]').addEventListener('click',()=>{show(active-1);start()});root.querySelector('[data-hero-next]').addEventListener('click',()=>{show(active+1);start()});dots.forEach((dot,i)=>dot.addEventListener('click',()=>{show(i);start()}));root.addEventListener('mouseenter',stop);root.addEventListener('mouseleave',start);root.addEventListener('focusin',stop);root.addEventListener('focusout',start);start()})();
</script>
}
</body></html>
