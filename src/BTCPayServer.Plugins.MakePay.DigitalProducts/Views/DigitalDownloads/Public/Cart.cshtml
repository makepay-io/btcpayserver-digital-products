@model DigitalCartViewModel
@{ Layout = null; var cartUrl = Url.Action("CartPage", new { storeId = Model.StoreId }); }
<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Cart · @Model.Settings.StorefrontTitle</title><partial name="~/Views/DigitalDownloads/Public/_Theme.cshtml" model="Model.Settings" /></head><body class="dp-public"><main class="dp-shell">
<header class="dp-topbar"><a class="dp-topbar-brand" asp-action="Storefront" asp-route-storeId="@Model.StoreId">@Model.Settings.StorefrontTitle</a><nav class="dp-topnav"><a class="dp-nav-link" asp-action="Storefront" asp-route-storeId="@Model.StoreId">Browse</a><a class="dp-nav-link" asp-action="Account" asp-route-storeId="@Model.StoreId">@(Model.CustomerEmail is null?"Sign in":"Purchases")</a><a class="dp-nav-link cart is-active" asp-action="CartPage" asp-route-storeId="@Model.StoreId">Cart · @Model.Lines.Sum(line=>line.Quantity)</a></nav></header>
<p class="dp-eyebrow">Your order</p><h1 class="dp-section-heading">Shopping cart</h1><p class="dp-section-copy">Review your digital products before opening the secure BTCPay checkout.</p>
@if(Model.Lines.Count==0){<div class="dp-empty"><p>Your cart is empty.</p><a class="dp-primary" asp-action="Storefront" asp-route-storeId="@Model.StoreId">Explore products</a></div>}else{
<div class="dp-card"><div class="dp-cart-head"><span>Product</span><span>Price</span><span>Quantity</span><span>Total</span></div>@foreach(var line in Model.Lines){<div class="dp-cart-row"><div class="dp-cart-product">@if(line.Product.ImageUrl is not null){<img class="dp-cart-thumb" src="@line.Product.ImageUrl" alt="">}<div class="dp-cart-name"><strong>@line.Product.Name</strong><span>@(line.Product.Kind==DigitalProductKind.Download?"Download":"License")</span><form method="post" asp-action="UpdateCart" asp-route-storeId="@Model.StoreId"><input type="hidden" name="kind" value="@line.Product.Kind"><input type="hidden" name="productId" value="@line.Product.Id"><input type="hidden" name="quantity" value="0"><button class="dp-link-button" type="submit">Remove</button></form></div></div><div>@line.Product.Price.ToString("0.00") @Model.Settings.Currency</div><form class="dp-qty-form" method="post" asp-action="UpdateCart" asp-route-storeId="@Model.StoreId"><input type="hidden" name="kind" value="@line.Product.Kind"><input type="hidden" name="productId" value="@line.Product.Id">@if(line.Product.Kind==DigitalProductKind.Download){<span>1</span><input type="hidden" name="quantity" value="1">}else{<input class="dp-qty" type="number" name="quantity" value="@line.Quantity" min="1" max="10" aria-label="Quantity for @line.Product.Name"><button class="dp-secondary" type="submit">Update</button>}</form><strong>@line.Total.ToString("0.00") @Model.Settings.Currency</strong></div>}</div>
<div class="dp-summary"><div class="dp-summary-row"><span>@Model.Lines.Sum(line=>line.Quantity) item@(Model.Lines.Sum(line=>line.Quantity)==1?"":"s")</span><span>Digital delivery</span></div><div class="dp-summary-row total"><span>Total</span><strong>@Model.Total.ToString("0.00") @Model.Settings.Currency</strong></div></div>
@if(Model.CustomerEmail is null){<div class="dp-auth-note">Sign in with a one-time email code before payment. This creates your private purchase library—no password required.</div>}
<div class="dp-actions"><a class="dp-secondary" asp-action="Storefront" asp-route-storeId="@Model.StoreId">Continue shopping</a>@if(Model.CustomerEmail is null){<a class="dp-primary" asp-action="Login" asp-route-storeId="@Model.StoreId" asp-route-returnUrl="@cartUrl">Sign in to checkout</a>}else{<form method="post" asp-action="Checkout" asp-route-storeId="@Model.StoreId"><button class="dp-primary" type="submit">Pay with BTCPay</button></form>}</div>}
<partial name="~/Views/DigitalDownloads/Public/_Footer.cshtml" model="Model.Settings" /></main></body></html>
