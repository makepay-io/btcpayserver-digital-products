            body=`<main class="pay${selectedClass('payment')}" data-editor-select data-editor-type="payment" data-editor-label="Payment"><img class="btcpay" src="${location.origin}/img/btcpay-logo.svg" alt="BTCPay Server"><div class="eyebrow">SECURE CHECKOUT</div><h1>Complete your payment</h1><p class="muted">BTCPay opens as a secure JavaScript modal. Products unlock automatically after settlement.</p><button>Open checkout</button></main>`;
        }else if(page==='success'){
            body=`<main class="success${selectedClass('success')}" data-editor-select data-editor-type="success" data-editor-label="Confirmation"><div class="eyebrow">ORDER COMPLETE</div><h1>${confirmTitle}</h1><p class="muted">${confirmMessage}</p><div class="library">${products.slice(0,2).map(product=>`<div class="card"><h3>${escapeHtml(product.name)}</h3><p class="muted">Available in your protected library.</p><button>Open product</button></div>`).join('')}</div></main>`;
        }else{
            body=`<main class="shell${selectedClass('library')}" data-editor-select data-editor-type="library" data-editor-label="Purchase library">${topbar(title)}<h1>${libraryTitle}</h1><p class="muted">${librarySubtitle}</p><div class="library">${products.slice(0,2).map(product=>`<div class="card"><h3>${escapeHtml(product.name)}</h3><p class="muted">Available · protected access</p><div class="key">MP-PRO-8F3C-291A</div></div>`).join('')}</div></main>`;
        }
        const existingDocument=frame.contentDocument;
        const existingStyle=existingDocument?.getElementById('dp-preview-style');
        pendingPreviewScroll=currentScroll;
        if(existingDocument?.body&&existingStyle){
            existingStyle.textContent=css;
            existingDocument.body.innerHTML=body;
            wirePreview();
            frame.contentWindow?.scrollTo(0,currentScroll);
        }else{
            frame.srcdoc=`<!doctype html><html><head><meta name="viewport" content="width=device-width,initial-scale=1"><style id="dp-preview-style">${css}</style></head><body>${body}</body></html>`;
        }
    };

    const updatePreviewSelection=()=>{
        const doc=frame.contentDocument;
        if(!doc)return;
        doc.querySelectorAll('.editor-selected').forEach(element=>element.classList.remove('editor-selected'));
        let selector=`[data-editor-type="${selected.type}"]`;
        if(selected.type==='hero')selector='[data-editor-type="slide"]';
        if((selected.type==='slide'||selected.type==='category')&&selected.index!==null)selector+=`[data-editor-index="${Number(selected.index)}"]`;
        const target=doc.querySelector(selector);
        if(!target)return;
        target.classList.add('editor-selected');
        const labels={hero:'Hero carousel',slide:`Hero slide ${Number(selected.index)+1}`,catalog:'Product catalog',category:'Category',header:'Header',announcement:'Announcement',footer:'Footer',product:'Product detail',cart:'Shopping cart',login:'Sign in',payment:'Payment',success:'Confirmation',library:'Purchase library'};
        target.setAttribute('data-editor-label',labels[selected.type]||'Selected');
    };
    const wirePreview=()=>{
        const doc=frame.contentDocument;
        if(!doc)return;
        doc.querySelectorAll('a,button').forEach(element=>element.addEventListener('click',event=>event.preventDefault()));
        doc.querySelectorAll('[data-editor-select]').forEach(element=>element.addEventListener('click',event=>{event.preventDefault();event.stopPropagation();select(element.dataset.editorType,element.dataset.editorIndex===undefined?null:Number(element.dataset.editorIndex))}));
        updatePreviewSelection();
    };
    const updateTopbar=()=>{
        dialog.querySelectorAll('[data-editor-mode]').forEach(button=>button.classList.toggle('is-active',button.dataset.editorMode===mode));
        dialog.querySelectorAll('[data-preview-device]').forEach(button=>button.classList.toggle('is-active',button.dataset.previewDevice===device));
        const addKind=selected.type==='catalog'||selected.type==='category'?'category':'slide';
        addButton.dataset.addKind=addKind;
        addButton.querySelector('span').textContent=addKind==='category'?'Add category':'Add slide';
        addButton.hidden=page!=='shop';
    };
    const renderAll=(options={})=>{renderSidebar();renderInspector(options.preserveInspectorScroll!==false);renderPreview(options.preservePreviewScroll!==false);updateTopbar();updateStatus()};
    const persistUiState=()=>{try{localStorage.setItem(storageKey,JSON.stringify({page,device,mode,selected,activeSlide}))}catch{}};
    const restoreUiState=()=>{try{const stored=JSON.parse(localStorage.getItem(storageKey)||'null');if(!stored)return;if(pageLabels[stored.page])page=stored.page;if(['desktop','mobile'].includes(stored.device))device=stored.device;if(stored.selected?.type)selected=stored.selected;if(Number.isInteger(stored.activeSlide))activeSlide=stored.activeSlide}catch{}};
    const addSlide=()=>mutate(()=>{if(slides.length>=12)return;slides.push({id:uid(),visible:true,eyebrow:'Featured',headline:'A new digital product',supportingCopy:'Describe what makes this offer valuable.',imageUrl:'',buttonText:'Explore products',linkUrl:'#products',productReference:null});activeSlide=slides.length-1;selected={type:'slide',index:activeSlide}});
    const addCategory=()=>mutate(()=>{if(categories.length>=24)return;const n=categories.length+1;categories.push({id:uid(),visible:true,name:`Category ${n}`,slug:`category-${n}`,rule:0,productReferences:[]});selected={type:'category',index:categories.length-1}});
    const moveLayer=(type,index,direction)=>mutate(()=>{const list=type==='slide'?slides:categories;const next=index+direction;if(index<0||next<0||next>=list.length)return;[list[index],list[next]]=[list[next],list[index]];selected={type,index:next};if(type==='slide')activeSlide=next});
    const removeLayer=(type,index)=>mutate(()=>{const list=type==='slide'?slides:categories;list.splice(index,1);const next=Math.max(0,Math.min(index,list.length-1));selected=list.length?{type,index:next}:{type:type==='slide'?'hero':'catalog',index:null};if(type==='slide')activeSlide=next});

    dialog.addEventListener('click',event=>{
        const selectTarget=event.target.closest('[data-select-type]');
        if(selectTarget){select(selectTarget.dataset.selectType,selectTarget.dataset.selectIndex===undefined?null:Number(selectTarget.dataset.selectIndex));return}
        const addTarget=event.target.closest('[data-add-kind]');
        if(addTarget){addTarget.dataset.addKind==='category'?addCategory():addSlide();return}
        const moveTarget=event.target.closest('[data-layer-move]');
        if(moveTarget){moveLayer(moveTarget.dataset.layerType,Number(moveTarget.dataset.layerIndex),moveTarget.dataset.layerMove==='up'?-1:1);return}
        const visibilityTarget=event.target.closest('[data-layer-visibility]');
        if(visibilityTarget){const type=visibilityTarget.dataset.layerVisibility,index=Number(visibilityTarget.dataset.layerIndex);mutate(()=>{(type==='slide'?slides:categories)[index].visible=!(type==='slide'?slides:categories)[index].visible});return}
        const removeTarget=event.target.closest('[data-remove-kind]');
        if(removeTarget){removeLayer(removeTarget.dataset.removeKind,Number(removeTarget.dataset.removeIndex));return}
    });
    dialog.addEventListener('focusin',event=>{if(event.target.matches('[data-bind-target],[data-bind-slide],[data-bind-category],[data-category-product]'))editStartSnapshot=capture()});
    dialog.addEventListener('input',event=>{
        const target=event.target;
        if(target.dataset.bindTarget){const field=source(target.dataset.bindTarget);if(field){if(field.type==='checkbox')field.checked=target.checked;else field.value=target.value}renderPreview();updateStatus();return}
        if(target.dataset.bindSlide){const slide=slides[Number(target.dataset.slideIndex)];if(slide){slide[target.dataset.bindSlide]=target.type==='checkbox'?target.checked:target.value;serialize();renderPreview();updateStatus()}return}
        if(target.dataset.bindCategory){const category=categories[Number(target.dataset.categoryIndex)];if(category){const field=target.dataset.bindCategory;category[field]=target.type==='checkbox'?target.checked:field==='rule'?Number(target.value):target.value;if(field==='name'&&!category.slug)category.slug=slugify(target.value);serialize();renderPreview();updateStatus()}return}
    });
    dialog.addEventListener('change',event=>{
        const target=event.target;
        if(target.matches('[data-bind-target],[data-bind-slide],[data-bind-category],[data-category-product]')){
            if(target.dataset.categoryProduct){const category=categories[Number(target.dataset.categoryIndex)],reference=target.dataset.categoryProduct,list=category.productReferences||[];category.productReferences=target.checked?[...new Set([...list,reference])]:list.filter(item=>item!==reference);serialize()}
            pushHistory(editStartSnapshot);editStartSnapshot=null;renderSidebar();renderInspector();renderPreview();updateStatus();
        }
        if(target.matches('[data-upload-logo]')&&target.files[0]){if(logoPreview)URL.revokeObjectURL(logoPreview);logoPreview=URL.createObjectURL(target.files[0]);uploadsDirty=true;uploadBin.appendChild(target);renderInspector();renderPreview();updateStatus()}
        if(target.matches('[data-upload-favicon]')&&target.files[0]){uploadsDirty=true;uploadBin.appendChild(target);renderInspector();updateStatus()}
        if(target.matches('[data-upload-slide]')&&target.files[0]){const index=Number(target.dataset.uploadSlide),slide=slides[index];if(slidePreviews[slide.id])URL.revokeObjectURL(slidePreviews[slide.id]);slidePreviews[slide.id]=URL.createObjectURL(target.files[0]);activeSlide=index;uploadsDirty=true;uploadBin.appendChild(target);renderInspector();renderPreview();updateStatus()}
    });
    sidebar.addEventListener('dragstart',event=>{const layer=event.target.closest('[data-layer-type][draggable=true]');if(!layer)return;draggedLayer={type:layer.dataset.layerType,index:Number(layer.dataset.layerIndex)};event.dataTransfer.effectAllowed='move'});
    sidebar.addEventListener('dragover',event=>{if(event.target.closest('[data-layer-type][draggable=true]'))event.preventDefault()});
    sidebar.addEventListener('drop',event=>{const target=event.target.closest('[data-layer-type][draggable=true]');if(!target||!draggedLayer||target.dataset.layerType!==draggedLayer.type)return;event.preventDefault();const targetIndex=Number(target.dataset.layerIndex);if(targetIndex===draggedLayer.index)return;mutate(()=>{const list=draggedLayer.type==='slide'?slides:categories;const [item]=list.splice(draggedLayer.index,1);list.splice(targetIndex,0,item);selected={type:draggedLayer.type,index:targetIndex};if(draggedLayer.type==='slide')activeSlide=targetIndex});draggedLayer=null});
    pageSelect.addEventListener('change',()=>{page=pageSelect.value;selected={type:page==='shop'?'hero':page,index:page==='shop'?0:null};mode=page==='shop'?'sections':'pages';renderAll({preservePreviewScroll:false,preserveInspectorScroll:false});persistUiState()});
    dialog.querySelectorAll('[data-preview-device]').forEach(button=>button.addEventListener('click',()=>{device=button.dataset.previewDevice;frameWrap.classList.toggle('is-mobile',device==='mobile');updateTopbar();persistUiState()}));
    dialog.querySelectorAll('[data-editor-mode]').forEach(button=>button.addEventListener('click',()=>{mode=button.dataset.editorMode;if(mode==='theme')select('general');else if(mode==='header')select('header');else if(mode==='footer')select('footer');else if(mode==='pages')select(page==='shop'?'catalog':page);else{selected={type:page==='shop'?'hero':page,index:page==='shop'?0:null};renderAll()}persistUiState()}));
    frame.addEventListener('load',()=>{wirePreview();frame.contentWindow?.scrollTo(0,pendingPreviewScroll)});
    undoButton.addEventListener('click',undo);
    redoButton.addEventListener('click',redo);
    window.addEventListener('keydown',event=>{if(!dialog.open||!(event.metaKey||event.ctrlKey)||event.key.toLowerCase()!=='z'||['INPUT','TEXTAREA','SELECT'].includes(document.activeElement?.tagName))return;event.preventDefault();event.shiftKey?redo():undo()});
    document.getElementById('open-dp-editor').addEventListener('click',()=>{restoreUiState();pageSelect.value=page;frameWrap.classList.toggle('is-mobile',device==='mobile');serialize();history=[];future=[];renderAll({preservePreviewScroll:false,preserveInspectorScroll:false});dialog.showModal()});
    document.getElementById('close-dp-editor').addEventListener('click',()=>{if(isDirty()&&!window.confirm('Close the editor with unsaved design changes?'))return;dialog.close()});
    saveButton.addEventListener('click',()=>{if(saveButton.disabled)return;serialize();dialog.classList.add('is-saving');saveButton.disabled=true;form.requestSubmit()});
    form.addEventListener('submit',()=>{serialize();const button=document.getElementById('dp-settings-submit');button.disabled=true;button.textContent='Saving…'});
    serialize();
    savedSignature=signature(capture());
})();
</script>
