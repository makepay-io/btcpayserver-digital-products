@model DigitalDownloadsSettings
@{ var storeId = ViewData["StoreId"]?.ToString(); ViewData.SetActivePage("DigitalDownloadsSettings", "Digital Downloads", "Storefront & delivery settings"); }
<h2>Storefront & delivery settings</h2><partial name="_StatusMessage" />
<form method="post" asp-action="SaveSettings" asp-route-storeId="@storeId"><div asp-validation-summary="All" class="text-danger"></div>
<div class="row g-4"><div class="col-lg-6"><div class="bg-tile rounded p-4"><h4>Branding</h4>
<div class="form-group"><label asp-for="StorefrontTitle" class="form-label"></label><input asp-for="StorefrontTitle" class="form-control" /></div>
<div class="form-group"><label asp-for="StorefrontDescription" class="form-label"></label><textarea asp-for="StorefrontDescription" class="form-control"></textarea></div>
<div class="row"><div class="col"><label asp-for="Currency" class="form-label"></label><input asp-for="Currency" class="form-control" /></div><div class="col"><label asp-for="AccentColor" class="form-label"></label><input asp-for="AccentColor" type="color" class="form-control form-control-color" /></div></div>
<div class="form-group"><label asp-for="LogoUrl" class="form-label"></label><input asp-for="LogoUrl" class="form-control" /></div><div class="form-group"><label asp-for="TermsUrl" class="form-label"></label><input asp-for="TermsUrl" class="form-control" /></div>
</div><div class="bg-tile rounded p-4 mt-4"><h4>Protection</h4><div class="row"><div class="col"><label asp-for="DefaultDownloadLimit" class="form-label"></label><input asp-for="DefaultDownloadLimit" class="form-control" /></div><div class="col"><label asp-for="DefaultLinkHours" class="form-label"></label><input asp-for="DefaultLinkHours" class="form-control" /></div></div><div class="form-check mt-3"><input asp-for="LockToFirstIp" class="form-check-input" /><label asp-for="LockToFirstIp" class="form-check-label">Lock link to first downloader IP</label></div><div class="form-check"><input asp-for="DeliverOnProcessing" class="form-check-input" /><label asp-for="DeliverOnProcessing" class="form-check-label">Deliver when invoice enters Processing (higher risk)</label></div></div></div>
<div class="col-lg-6"><div class="bg-tile rounded p-4"><h4>S3-compatible storage</h4><div class="form-group"><label asp-for="S3Endpoint" class="form-label"></label><input asp-for="S3Endpoint" class="form-control" /></div><div class="row"><div class="col"><label asp-for="S3Region" class="form-label"></label><input asp-for="S3Region" class="form-control" /></div><div class="col"><label asp-for="S3Bucket" class="form-label"></label><input asp-for="S3Bucket" class="form-control" /></div></div><div class="form-group"><label asp-for="S3AccessKey" class="form-label"></label><input asp-for="S3AccessKey" class="form-control" /></div><div class="form-group"><label class="form-label">S3 secret key</label><input type="password" name="s3SecretKey" autocomplete="new-password" class="form-control" placeholder="Leave blank to keep existing" /></div></div>
<div class="bg-tile rounded p-4 mt-4"><h4>Custom URL authentication</h4><div class="form-group"><label asp-for="RemoteAuthorizationHeader" class="form-label">Header name</label><input asp-for="RemoteAuthorizationHeader" class="form-control" placeholder="Authorization" /></div><div class="form-group"><label class="form-label">Header value</label><input type="password" name="remoteAuthorizationValue" autocomplete="new-password" class="form-control" placeholder="Bearer … (leave blank to keep)" /></div></div>
<div class="bg-tile rounded p-4 mt-4"><h4>Delivery email</h4><div class="form-check"><input asp-for="EmailDeliveryEnabled" class="form-check-input" /><label asp-for="EmailDeliveryEnabled" class="form-check-label">Send through BTCPay store SMTP</label></div><div class="form-group mt-3"><label asp-for="EmailSubject" class="form-label"></label><input asp-for="EmailSubject" class="form-control" /></div><div class="form-group"><label asp-for="EmailHtml" class="form-label"></label><textarea asp-for="EmailHtml" rows="8" class="form-control font-monospace"></textarea><div class="form-text">Placeholders: {StoreName}, {ProductName}, {DownloadUrl}, {ExpiresAt}</div></div></div></div></div>
<button class="btn btn-primary mt-4">Save settings</button> <a class="btn btn-secondary mt-4" asp-action="Index" asp-route-storeId="@storeId">Back</a></form>
