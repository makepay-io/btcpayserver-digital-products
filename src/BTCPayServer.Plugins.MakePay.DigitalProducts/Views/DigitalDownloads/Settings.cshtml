@model DigitalDownloadsSettings
@{ var storeId = ViewData["StoreId"]?.ToString(); var previewStoreUrl = ViewData["PreviewStoreUrl"]?.ToString(); }
<style>
    .dp-settings-header{display:flex;align-items:flex-start;justify-content:space-between;gap:20px;margin-bottom:24px}.dp-settings-header p{max-width:720px}.dp-settings-actions{display:flex;flex-wrap:wrap;gap:8px}.dp-settings-card{height:100%}.dp-settings-card h4{margin-bottom:4px}.dp-settings-card>.text-muted{margin-bottom:22px}.dp-editor-dialog{width:100vw;height:100vh;max-width:none;max-height:none;margin:0;border:0;padding:0;background:#101828;color:#fff}.dp-editor-dialog::backdrop{background:rgba(16,24,40,.8)}.dp-editor-shell{height:100%;display:grid;grid-template-rows:auto 1fr}.dp-editor-header{display:flex;align-items:center;justify-content:space-between;gap:18px;padding:14px 18px;border-bottom:1px solid #344054;background:#101828}.dp-editor-header strong{font-size:1.05rem}.dp-editor-header-actions,.dp-editor-toolbar,.dp-editor-state{display:flex;gap:8px;align-items:center}.dp-editor-header button,.dp-editor-toolbar button,.dp-editor-state button{border:1px solid #475467;background:#1d2939;color:#fff;border-radius:8px;padding:8px 11px;font-weight:700}.dp-editor-header button.primary{background:#155eef;border-color:#155eef}.dp-editor-body{min-height:0;display:grid;grid-template-columns:340px 1fr}.dp-editor-controls{overflow:auto;background:#1d2939;padding:20px;border-right:1px solid #344054}.dp-editor-controls h3{font-size:.76rem;letter-spacing:.09em;text-transform:uppercase;color:#98a2b3;margin:24px 0 12px}.dp-editor-controls h3:first-child{margin-top:0}.dp-editor-controls label{display:block;font-size:.8rem;font-weight:700;margin:0 0 6px}.dp-editor-controls input,.dp-editor-controls select,.dp-editor-controls textarea{width:100%;border:1px solid #475467;border-radius:8px;background:#101828;color:#fff;padding:9px 10px;margin-bottom:12px}.dp-editor-controls input[type=color]{height:42px;padding:4px}.dp-editor-color-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}.dp-editor-preview{min-width:0;min-height:0;display:grid;grid-template-rows:auto 1fr;background:#344054}.dp-editor-toolbar{justify-content:space-between;padding:10px 14px;background:#1d2939}.dp-editor-toolbar button.is-active,.dp-editor-state button.is-active{background:#155eef;border-color:#155eef}.dp-editor-canvas{display:grid;place-items:center;overflow:auto;padding:20px}.dp-editor-frame-wrap{width:100%;height:100%;min-height:600px;transition:width .2s ease}.dp-editor-frame-wrap.is-mobile{width:390px;max-width:100%;height:760px;min-height:0}.dp-editor-frame{display:block;width:100%;height:100%;border:0;background:#fff;box-shadow:0 18px 50px rgba(0,0,0,.32)}@@media(max-width:850px){.dp-editor-body{grid-template-columns:1fr}.dp-editor-controls{display:none}.dp-editor-state{overflow:auto}.dp-editor-toolbar{align-items:flex-start;flex-direction:column}.dp-settings-header{flex-direction:column}}
</style>
<div class="dp-settings-header">
    <div><h2 class="mb-1">Digital product experience</h2><p class="text-muted mb-0">Design the public shop, passwordless sign-in, cart, payment handoff, confirmation, and customer purchase library. The fullscreen editor previews every state before you save.</p></div>
    <div class="dp-settings-actions"><button type="button" class="btn btn-primary" id="open-dp-editor">Open live editor</button>@if(previewStoreUrl is not null){<a class="btn btn-secondary" href="@previewStoreUrl" target="_blank">View shop</a>}<a class="btn btn-secondary" asp-action="Index" asp-route-storeId="@storeId">Back</a></div>
</div>
<partial name="_StatusMessage" />
<form method="post" asp-action="SaveSettings" asp-route-storeId="@storeId" id="dp-settings-form">
    <div asp-validation-summary="All" class="text-danger"></div><input asp-for="CustomerAccountsEnabled" type="hidden" value="true">
    <div class="row g-4">
        <div class="col-xl-6"><section class="bg-tile rounded p-4 dp-settings-card"><h4>Brand &amp; storefront</h4><p class="text-muted">Identity, public copy, typeface, hero layout, and product catalog.</p>
            <div class="form-group"><label asp-for="StorefrontTitle" class="form-label">Storefront name</label><input asp-for="StorefrontTitle" class="form-control"></div>
            <div class="form-group"><label asp-for="StorefrontDescription" class="form-label">Storefront description</label><textarea asp-for="StorefrontDescription" class="form-control" rows="2"></textarea></div>
            <div class="row"><div class="col-md-6 form-group"><label asp-for="LogoUrl" class="form-label">Logo URL</label><input asp-for="LogoUrl" class="form-control" placeholder="https://..."></div><div class="col-md-6 form-group"><label asp-for="HeroImageUrl" class="form-label">Hero image URL</label><input asp-for="HeroImageUrl" class="form-control" placeholder="https://..."></div></div>
            <div class="form-group"><label asp-for="HeroEyebrow" class="form-label">Hero eyebrow</label><input asp-for="HeroEyebrow" class="form-control"></div><div class="form-group"><label asp-for="HeroHeadline" class="form-label">Hero headline</label><input asp-for="HeroHeadline" class="form-control"></div><div class="form-group"><label asp-for="HeroSubheadline" class="form-label">Hero supporting copy</label><textarea asp-for="HeroSubheadline" class="form-control" rows="2"></textarea></div>
            <div class="row"><div class="col-md-6 form-group"><label asp-for="CatalogTitle" class="form-label">Catalog title</label><input asp-for="CatalogTitle" class="form-control"></div><div class="col-md-6 form-group"><label asp-for="CatalogSubtitle" class="form-label">Catalog subtitle</label><input asp-for="CatalogSubtitle" class="form-control"></div></div>
            <div class="row"><div class="col-md-4 form-group"><label asp-for="FontStyle" class="form-label">Typeface style</label><select asp-for="FontStyle" asp-items="Html.GetEnumSelectList<DigitalStoreFontStyle>()" class="form-select"></select></div><div class="col-md-4 form-group"><label asp-for="BrandPanelWidth" class="form-label">Hero width (%)</label><input asp-for="BrandPanelWidth" class="form-control"></div><div class="col-md-4 form-group"><label asp-for="Currency" class="form-label"></label><input asp-for="Currency" class="form-control"></div></div>
            <div class="row g-3"><div class="col-6 col-md-4"><label asp-for="AccentColor" class="form-label">Accent</label><input asp-for="AccentColor" type="color" class="form-control form-control-color w-100"></div><div class="col-6 col-md-4"><label asp-for="AccentTextColor" class="form-label">Button text</label><input asp-for="AccentTextColor" type="color" class="form-control form-control-color w-100"></div><div class="col-6 col-md-4"><label asp-for="BrandTextColor" class="form-label">Hero text</label><input asp-for="BrandTextColor" type="color" class="form-control form-control-color w-100"></div><div class="col-6 col-md-4"><label asp-for="PageBackgroundColor" class="form-label">Page</label><input asp-for="PageBackgroundColor" type="color" class="form-control form-control-color w-100"></div><div class="col-6 col-md-4"><label asp-for="SurfaceColor" class="form-label">Cards</label><input asp-for="SurfaceColor" type="color" class="form-control form-control-color w-100"></div><div class="col-6 col-md-4"><label asp-for="TextColor" class="form-label">Text</label><input asp-for="TextColor" type="color" class="form-control form-control-color w-100"></div><div class="col-6 col-md-4"><label asp-for="MutedColor" class="form-label">Muted text</label><input asp-for="MutedColor" type="color" class="form-control form-control-color w-100"></div><div class="col-6 col-md-4"><label asp-for="SoftColor" class="form-label">Soft surface</label><input asp-for="SoftColor" type="color" class="form-control form-control-color w-100"></div></div>
        </section></div>
        <div class="col-xl-6"><section class="bg-tile rounded p-4 dp-settings-card"><h4>Customer access &amp; completion</h4><p class="text-muted">Passwordless access, purchase library, confirmation, and public policies.</p>
            <div class="row"><div class="col-md-6 form-group"><label asp-for="LoginCodeMinutes" class="form-label">Login code lifetime (minutes)</label><input asp-for="LoginCodeMinutes" class="form-control"></div><div class="col-md-6 form-group"><label asp-for="CustomerSessionHours" class="form-label">Customer session (hours)</label><input asp-for="CustomerSessionHours" class="form-control"></div></div>
            <div class="form-group"><label asp-for="LibraryTitle" class="form-label">Library title</label><input asp-for="LibraryTitle" class="form-control"></div><div class="form-group"><label asp-for="LibrarySubtitle" class="form-label">Library subtitle</label><textarea asp-for="LibrarySubtitle" class="form-control" rows="2"></textarea></div>
            <div class="form-group"><label asp-for="ConfirmationTitle" class="form-label">Confirmation title</label><input asp-for="ConfirmationTitle" class="form-control"></div><div class="form-group"><label asp-for="ConfirmationMessage" class="form-label">Confirmation message</label><textarea asp-for="ConfirmationMessage" class="form-control" rows="2"></textarea></div>
            <div class="row"><div class="col-md-6 form-group"><label asp-for="PrivacyUrl" class="form-label">Privacy URL</label><input asp-for="PrivacyUrl" class="form-control"></div><div class="col-md-6 form-group"><label asp-for="TermsUrl" class="form-label">Terms URL</label><input asp-for="TermsUrl" class="form-control"></div></div><div class="form-group"><label asp-for="FooterText" class="form-label">Footer text</label><textarea asp-for="FooterText" class="form-control" rows="2"></textarea></div>
            <h5 class="mt-4">Passwordless sign-in email</h5><div class="form-group"><label asp-for="LoginEmailSubject" class="form-label">Subject</label><input asp-for="LoginEmailSubject" class="form-control"></div><div class="form-group"><label asp-for="LoginEmailHtml" class="form-label">HTML template</label><textarea asp-for="LoginEmailHtml" rows="6" class="form-control font-monospace"></textarea><div class="form-text">Available: {StoreName}, {Code}, {Minutes}</div></div>
            <h5 class="mt-4">Purchase email</h5><div class="form-group"><label asp-for="PurchaseEmailSubject" class="form-label">Subject</label><input asp-for="PurchaseEmailSubject" class="form-control"></div><div class="form-group"><label asp-for="PurchaseEmailHtml" class="form-label">HTML template</label><textarea asp-for="PurchaseEmailHtml" rows="6" class="form-control font-monospace"></textarea><div class="form-text">Available: {StoreName}, {PurchaseUrl}, {LibraryUrl}</div></div>
        </section></div>
        <div class="col-xl-6"><section class="bg-tile rounded p-4 dp-settings-card"><h4>Download protection &amp; storage</h4><p class="text-muted">Protected link lifetime, local/S3 delivery, and authenticated custom URLs.</p>
            <div class="row"><div class="col-md-6 form-group"><label asp-for="DefaultDownloadLimit" class="form-label">Default download limit</label><input asp-for="DefaultDownloadLimit" class="form-control"></div><div class="col-md-6 form-group"><label asp-for="DefaultLinkHours" class="form-label">Default link lifetime (hours)</label><input asp-for="DefaultLinkHours" class="form-control"></div></div>
            <div class="form-check mb-2"><input asp-for="LockToFirstIp" class="form-check-input"><label asp-for="LockToFirstIp" class="form-check-label">Lock a link to the first downloader IP</label></div><div class="form-check mb-3"><input asp-for="DeliverOnProcessing" class="form-check-input"><label asp-for="DeliverOnProcessing" class="form-check-label">Deliver at Processing (higher payment risk)</label></div>
            <h5>S3-compatible storage</h5><div class="form-group"><label asp-for="S3Endpoint" class="form-label">Endpoint</label><input asp-for="S3Endpoint" class="form-control"></div><div class="row"><div class="col-md-6 form-group"><label asp-for="S3Region" class="form-label">Region</label><input asp-for="S3Region" class="form-control"></div><div class="col-md-6 form-group"><label asp-for="S3Bucket" class="form-label">Bucket</label><input asp-for="S3Bucket" class="form-control"></div></div><div class="form-group"><label asp-for="S3AccessKey" class="form-label">Access key</label><input asp-for="S3AccessKey" class="form-control"></div><div class="form-group"><label class="form-label">Secret key</label><input type="password" name="s3SecretKey" autocomplete="new-password" class="form-control" placeholder="Leave blank to keep existing"></div>
            <h5 class="mt-4">Custom URL authentication</h5><div class="form-group"><label asp-for="RemoteAuthorizationHeader" class="form-label">Header name</label><input asp-for="RemoteAuthorizationHeader" class="form-control" placeholder="Authorization"></div><div class="form-group"><label class="form-label">Header value</label><input type="password" name="remoteAuthorizationValue" autocomplete="new-password" class="form-control" placeholder="Bearer … (leave blank to keep)"></div>
        </section></div>
        <div class="col-xl-6"><section class="bg-tile rounded p-4 dp-settings-card"><h4>Legacy delivery &amp; MakePay</h4><p class="text-muted">Compatibility email for older single-item links and optional MakePay attribution.</p>
            <div class="form-check mb-3"><input asp-for="EmailDeliveryEnabled" class="form-check-input"><label asp-for="EmailDeliveryEnabled" class="form-check-label">Send delivery email through BTCPay store SMTP</label></div><div class="form-group"><label asp-for="EmailSubject" class="form-label">Legacy email subject</label><input asp-for="EmailSubject" class="form-control"></div><div class="form-group"><label asp-for="EmailHtml" class="form-label">Legacy HTML template</label><textarea asp-for="EmailHtml" rows="7" class="form-control font-monospace"></textarea><div class="form-text">Available: {StoreName}, {ProductName}, {DownloadUrl}, {ExpiresAt}</div></div>
            <div class="form-check mt-4 mb-3"><input asp-for="ShowMakePayPromotion" class="form-check-input"><label asp-for="ShowMakePayPromotion" class="form-check-label">Show MakePay promotion on public pages</label></div><div class="form-group"><label asp-for="PromotionText" class="form-label">Promotion text</label><input asp-for="PromotionText" class="form-control"></div>
        </section></div>
    </div>
    <button class="btn btn-primary mt-4">Save settings</button>
</form>

<dialog class="dp-editor-dialog" id="dp-editor" aria-label="Live digital shop editor"><div class="dp-editor-shell">
    <header class="dp-editor-header"><div><strong>Live digital shop editor</strong><div class="small text-muted">Preview public states without leaving BTCPay.</div></div><div class="dp-editor-header-actions"><button type="button" id="close-dp-editor">Close</button><button type="button" class="primary" id="save-dp-editor">Save design</button></div></header>
    <div class="dp-editor-body"><aside class="dp-editor-controls">
        <h3>Brand</h3><label for="editor-StorefrontTitle">Storefront name</label><input id="editor-StorefrontTitle" data-editor-target="StorefrontTitle"><label for="editor-LogoUrl">Logo URL</label><input id="editor-LogoUrl" data-editor-target="LogoUrl"><label for="editor-HeroImageUrl">Hero image URL</label><input id="editor-HeroImageUrl" data-editor-target="HeroImageUrl"><label for="editor-HeroEyebrow">Eyebrow</label><input id="editor-HeroEyebrow" data-editor-target="HeroEyebrow"><label for="editor-HeroHeadline">Headline</label><textarea id="editor-HeroHeadline" data-editor-target="HeroHeadline" rows="2"></textarea><label for="editor-HeroSubheadline">Supporting copy</label><textarea id="editor-HeroSubheadline" data-editor-target="HeroSubheadline" rows="2"></textarea>
        <h3>Page copy</h3><label for="editor-CatalogTitle">Catalog title</label><input id="editor-CatalogTitle" data-editor-target="CatalogTitle"><label for="editor-CatalogSubtitle">Catalog subtitle</label><textarea id="editor-CatalogSubtitle" data-editor-target="CatalogSubtitle" rows="2"></textarea><label for="editor-LibraryTitle">Library title</label><input id="editor-LibraryTitle" data-editor-target="LibraryTitle"><label for="editor-LibrarySubtitle">Library subtitle</label><textarea id="editor-LibrarySubtitle" data-editor-target="LibrarySubtitle" rows="2"></textarea><label for="editor-ConfirmationTitle">Confirmation title</label><input id="editor-ConfirmationTitle" data-editor-target="ConfirmationTitle"><label for="editor-ConfirmationMessage">Confirmation message</label><textarea id="editor-ConfirmationMessage" data-editor-target="ConfirmationMessage" rows="2"></textarea>
        <h3>Layout &amp; colors</h3><label for="editor-FontStyle">Typeface style</label><select id="editor-FontStyle" data-editor-target="FontStyle"><option value="0">System sans</option><option value="1">Modern sans</option><option value="2">Rounded sans</option><option value="3">Editorial serif</option><option value="4">Neo-grotesk sans</option></select><label for="editor-BrandPanelWidth">Hero width</label><input id="editor-BrandPanelWidth" data-editor-target="BrandPanelWidth" type="range" min="35" max="60"><div class="dp-editor-color-grid"><div><label for="editor-AccentColor">Accent</label><input id="editor-AccentColor" data-editor-target="AccentColor" type="color"></div><div><label for="editor-AccentTextColor">Button text</label><input id="editor-AccentTextColor" data-editor-target="AccentTextColor" type="color"></div><div><label for="editor-BrandTextColor">Hero text</label><input id="editor-BrandTextColor" data-editor-target="BrandTextColor" type="color"></div><div><label for="editor-PageBackgroundColor">Page</label><input id="editor-PageBackgroundColor" data-editor-target="PageBackgroundColor" type="color"></div><div><label for="editor-SurfaceColor">Cards</label><input id="editor-SurfaceColor" data-editor-target="SurfaceColor" type="color"></div><div><label for="editor-TextColor">Text</label><input id="editor-TextColor" data-editor-target="TextColor" type="color"></div><div><label for="editor-MutedColor">Muted</label><input id="editor-MutedColor" data-editor-target="MutedColor" type="color"></div><div><label for="editor-SoftColor">Soft</label><input id="editor-SoftColor" data-editor-target="SoftColor" type="color"></div></div>
    </aside><section class="dp-editor-preview"><div class="dp-editor-toolbar"><div class="dp-editor-state"><button type="button" data-preview-state="shop" class="is-active">Shop</button><button type="button" data-preview-state="cart">Cart</button><button type="button" data-preview-state="login">Sign in</button><button type="button" data-preview-state="payment">Payment</button><button type="button" data-preview-state="success">Success</button><button type="button" data-preview-state="library">Library</button></div><div><button type="button" data-preview-device="desktop" class="is-active">Desktop</button> <button type="button" data-preview-device="mobile">Mobile</button></div></div><div class="dp-editor-canvas"><div class="dp-editor-frame-wrap"><iframe class="dp-editor-frame" id="dp-editor-frame" sandbox title="Digital shop preview"></iframe></div></div></section></div>
</div></dialog>
<script>
(()=>{const dialog=document.getElementById('dp-editor'),form=document.getElementById('dp-settings-form'),frame=document.getElementById('dp-editor-frame'),wrap=frame.closest('.dp-editor-frame-wrap'),editorFields=[...dialog.querySelectorAll('[data-editor-target]')];let state='shop';
const source=id=>document.getElementById(id),value=id=>source(id)?.value||'',escapeHtml=text=>String(text||'').replace(/[&<>\"]/g,char=>({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;'}[char])),color=(id,fallback)=>/^#[0-9a-f]{6}$/i.test(value(id))?value(id):fallback,url=id=>{try{const parsed=new URL(value(id));return /^https?:$/.test(parsed.protocol)?parsed.href:''}catch{return''}};
const syncFromForm=()=>editorFields.forEach(field=>{const target=source(field.dataset.editorTarget);if(target)field.value=target.value});const font=()=>({0:"system-ui,-apple-system,'Segoe UI',sans-serif",1:"'Helvetica Neue',Inter,system-ui,-apple-system,'Segoe UI',sans-serif",2:"ui-rounded,'Arial Rounded MT Bold',system-ui,sans-serif",3:"Georgia,'Times New Roman',serif",4:"Arial,Helvetica,sans-serif"}[value('FontStyle')]||"'Helvetica Neue',Inter,system-ui,sans-serif");
const topbar=title=>`<header class="top"><b>${title}</b><nav>Browse &nbsp; Purchases &nbsp; <span>Cart · 2</span></nav></header>`;const product=(kind,name,price,badge)=>`<article class="product"><small>${kind}</small>${badge?`<i>${badge}</i>`:''}<h3>${name}</h3><p>Professional digital delivery with protected customer access.</p><div class="buy"><b>${price} USD</b><button>Add to cart</button></div></article>`;
const render=()=>{const accent=color('AccentColor','#155eef'),accentText=color('AccentTextColor','#fff'),brandText=color('BrandTextColor','#fff'),page=color('PageBackgroundColor','#fff'),surface=color('SurfaceColor','#fff'),text=color('TextColor','#101828'),muted=color('MutedColor','#667085'),soft=color('SoftColor','#f8fafc'),image=url('HeroImageUrl'),logo=url('LogoUrl'),title=escapeHtml(value('StorefrontTitle')),headline=escapeHtml(value('HeroHeadline')),eyebrow=escapeHtml(value('HeroEyebrow')),sub=escapeHtml(value('HeroSubheadline')),catalogTitle=escapeHtml(value('CatalogTitle')),catalogSubtitle=escapeHtml(value('CatalogSubtitle')),libraryTitle=escapeHtml(value('LibraryTitle')),librarySubtitle=escapeHtml(value('LibrarySubtitle')),confirmTitle=escapeHtml(value('ConfirmationTitle')),confirmMessage=escapeHtml(value('ConfirmationMessage'));
const css=`*{box-sizing:border-box}body{margin:0;background:${page};color:${text};font:15px/1.45 ${font()}}button{font:inherit;background:${accent};color:${accentText};border:0;border-radius:9px;padding:11px 16px;font-weight:800}.split{display:grid;grid-template-columns:${Number(value('BrandPanelWidth'))||46}% 1fr;min-height:100vh}.brand{position:relative;overflow:hidden;background:${accent};color:${brandText};padding:50px;display:flex;flex-direction:column;justify-content:flex-end}.brand>img.hero{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.55}.brand-content{position:relative}.logo{max-height:48px;max-width:190px;margin-bottom:30px}.wordmark{font-weight:900;text-transform:uppercase;margin-bottom:30px}.eyebrow,small{font-size:11px;letter-spacing:.13em;text-transform:uppercase;font-weight:900}.brand h1{font-size:55px;line-height:.92;letter-spacing:-.05em;text-transform:uppercase;margin:10px 0;max-width:10ch}.brand p{max-width:36em}.shop,.shell{padding:34px 42px}.top{display:flex;justify-content:space-between;gap:18px;align-items:center;margin-bottom:42px;font-size:13px;text-transform:uppercase}.top span{background:${accent};color:${accentText};padding:8px 10px;border-radius:8px}.shop h2,.shell h1{font-size:34px;line-height:1;text-transform:uppercase;margin:0}.muted{color:${muted}}.products,.library{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:26px}.product,.card,.auth,.pay,.success{border:1px solid #e4e7ec;border-radius:15px;background:${surface};padding:22px}.product small{color:${accent}}.product i{display:block;width:max-content;margin-top:8px;background:${soft};color:${accent};border-radius:999px;padding:4px 8px;font-size:10px;font-style:normal;font-weight:900}.product h3{margin:10px 0 5px}.product p{color:${muted};font-size:13px}.buy{display:flex;justify-content:space-between;align-items:center;border-top:1px solid #e4e7ec;padding-top:16px;margin-top:16px}.shell{max-width:1000px;margin:auto}.rows{border:1px solid #e4e7ec;border-radius:14px;overflow:hidden;margin-top:24px}.row{display:grid;grid-template-columns:1fr 110px 90px 120px;gap:15px;padding:17px 20px;border-top:1px solid #e4e7ec}.row:first-child{background:${soft};border:0;font-size:11px;font-weight:900}.summary{margin:20px 0 0 auto;width:390px;background:${soft};border-radius:14px;padding:20px}.summary div{display:flex;justify-content:space-between;margin:8px}.auth,.pay{max-width:520px;margin:9vh auto;padding:34px;box-shadow:0 20px 50px rgba(16,24,40,.1)}.field{height:45px;border:1px solid #d0d5dd;border-radius:9px;margin:8px 0 15px}.auth button,.pay button{width:100%}.btcpay{display:block;width:180px;max-width:70%;margin:0 auto 24px}.success{max-width:780px;margin:7vh auto;border:0}.success h1{font-size:52px;letter-spacing:-.04em;margin:12px 0}.success-mark{width:60px;height:60px;border-radius:50%;background:#dcfae6;margin-bottom:20px}.library .card h3{margin-top:0}.key{font-family:monospace;background:${soft};border-radius:8px;padding:10px}.status{color:#067647;font-size:11px;font-weight:900;text-transform:uppercase}@@media(max-width:600px){.split{display:block}.brand{min-height:330px;padding:28px}.brand h1{font-size:38px}.shop,.shell{padding:28px 18px}.products,.library{grid-template-columns:1fr}.top nav{display:none}.rows .row{grid-template-columns:1fr auto}.rows .row span:nth-child(2),.rows .row span:nth-child(3){display:none}.summary{width:100%}.success h1{font-size:40px}}`;
let body;if(state==='shop'){body=`<main class="split"><aside class="brand">${image?`<img class="hero" src="${escapeHtml(image)}" alt="">`:''}<div class="brand-content">${logo?`<img class="logo" src="${escapeHtml(logo)}" alt="">`:`<div class="wordmark">${title}</div>`}<div class="eyebrow">${eyebrow}</div><h1>${headline}</h1><p>${sub}</p><b>PROTECTED DELIVERY · DIRECT BTCPAY CHECKOUT</b></div></aside><section class="shop">${topbar(title)}<div class="eyebrow">DIGITAL STOREFRONT</div><h2>${catalogTitle}</h2><p class="muted">${catalogSubtitle}</p><div class="products">${product('Digital download','Commerce field guide','9.99','POPULAR')}${product('Software license','MakePay Pro license','49.00','')}</div></section></main>`}else if(state==='cart'){body=`<main class="shell">${topbar(title)}<div class="eyebrow">YOUR ORDER</div><h1>Shopping cart</h1><p class="muted">Review your digital products before opening the secure BTCPay checkout.</p><div class="rows"><div class="row"><span>PRODUCT</span><span>PRICE</span><span>QUANTITY</span><span>TOTAL</span></div><div class="row"><b>Commerce field guide</b><span>9.99 USD</span><span>1</span><b>9.99 USD</b></div><div class="row"><b>MakePay Pro license</b><span>49.00 USD</span><span>1</span><b>49.00 USD</b></div></div><div class="summary"><div><span>2 items</span><span>Digital delivery</span></div><div><b>Total</b><b>58.99 USD</b></div><button style="width:100%">Pay with BTCPay</button></div></main>`}else if(state==='login'){body=`<main class="auth"><div class="wordmark">${title}</div><div class="eyebrow">PRIVATE CUSTOMER ACCESS</div><h1>Sign in without a password</h1><p class="muted">We’ll email a one-time code so you can check out and return to your purchases later.</p><b>Email</b><div class="field"></div><button>Email my sign-in code</button></main>`}else if(state==='payment'){body=`<main class="pay"><img class="btcpay" src="${location.origin}/img/btcpay-logo.svg" alt="BTCPay Server"><div class="eyebrow">SECURE CHECKOUT</div><h1>Complete your payment</h1><p class="muted">BTCPay opens as a secure JavaScript modal. Products unlock automatically after settlement.</p><button>Open checkout</button></main>`}else if(state==='success'){body=`<main class="success"><div class="success-mark"></div><div class="eyebrow">ORDER COMPLETE</div><h1>${confirmTitle}</h1><p class="muted">${confirmMessage}</p><div class="library"><div class="card"><h3>Commerce field guide</h3><p class="muted">0 of 5 downloads used</p><button>Download file</button></div><div class="card"><h3>MakePay Pro license</h3><p class="muted">Active · 0 of 3 activations</p><div class="key">MP-PRO-8F3C-291A</div></div></div></main>`}else{body=`<main class="shell">${topbar(title)}<div class="eyebrow">SIGNED IN AS CUSTOMER@EXAMPLE.COM</div><h1>${libraryTitle}</h1><p class="muted">${librarySubtitle}</p><div class="library"><div class="card"><h3>Downloads · 1</h3><p><b>Commerce field guide</b></p><p class="muted">0 of 5 downloads used</p><button>Download file</button></div><div class="card"><h3>Licenses · 1</h3><p><b>MakePay Pro license</b></p><span class="status">ACTIVE</span><div class="key">MP-PRO-8F3C-291A</div></div></div></main>`}frame.srcdoc=`<!doctype html><meta name="viewport" content="width=device-width,initial-scale=1"><style>${css}</style>${body}`};
editorFields.forEach(field=>field.addEventListener('input',()=>{const target=source(field.dataset.editorTarget);if(target){target.value=field.value;target.dispatchEvent(new Event('change',{bubbles:true}))}render()}));document.getElementById('open-dp-editor').addEventListener('click',()=>{syncFromForm();render();dialog.showModal()});document.getElementById('close-dp-editor').addEventListener('click',()=>dialog.close());document.getElementById('save-dp-editor').addEventListener('click',()=>{dialog.close();form.requestSubmit()});dialog.querySelectorAll('[data-preview-state]').forEach(button=>button.addEventListener('click',()=>{dialog.querySelectorAll('[data-preview-state]').forEach(item=>item.classList.remove('is-active'));button.classList.add('is-active');state=button.dataset.previewState;render()}));dialog.querySelectorAll('[data-preview-device]').forEach(button=>button.addEventListener('click',()=>{dialog.querySelectorAll('[data-preview-device]').forEach(item=>item.classList.remove('is-active'));button.classList.add('is-active');wrap.classList.toggle('is-mobile',button.dataset.previewDevice==='mobile')}));})();
</script>
