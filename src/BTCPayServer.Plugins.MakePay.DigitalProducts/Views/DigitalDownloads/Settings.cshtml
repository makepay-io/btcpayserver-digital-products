@using System.Text.Json
@model DigitalDownloadsSettings
@{
    var storeId = ViewData["StoreId"]?.ToString();
    var previewStoreUrl = ViewData["PreviewStoreUrl"]?.ToString();
    var canonicalStoreUrl = Url.Action("Storefront", "DigitalDownloadsPublic", new { storeId }, Context.Request.Scheme);
    var catalogOptions = ViewData["CatalogOptions"] as IReadOnlyList<StoreProductViewModel> ?? [];
    var jsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var heroSlidesJson = JsonSerializer.Serialize(Model.EffectiveHeroSlides(), jsonOptions);
    var categoriesJson = JsonSerializer.Serialize(Model.EffectiveStorefrontCategories(), jsonOptions);
    var catalogJson = JsonSerializer.Serialize(catalogOptions.Select(product => new
    {
        reference = DigitalStorefrontBuilder.ProductReference(product),
        anchor = DigitalStorefrontBuilder.ProductAnchor(product),
        kind = product.Kind.ToString(),
        productType = product.ProductType?.ToString(),
        typeLabel = DigitalStorefrontBuilder.ProductTypeLabel(product),
        name = product.Name,
        description = product.Description,
        price = product.Price.ToString("0.00"),
        meta = product.Meta,
        image = product.ImageUrl ?? Url.Action("ProductAsset", "DigitalDownloadsPublic", new { storeId, kind = DigitalStorefrontBuilder.ProductAssetKind(product) })
    }), jsonOptions);
    var heroFallbackAsset = Url.Action("HeroAsset", "DigitalDownloadsPublic", new { storeId });
}
