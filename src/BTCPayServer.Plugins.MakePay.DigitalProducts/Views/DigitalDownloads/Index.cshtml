@model DigitalDownloadsDashboardViewModel
@inject DisplayFormatter DisplayFormatter
@{ ViewData.SetActivePage("DigitalDownloads", "Digital Products", "Downloads"); }
<div class="sticky-header d-flex justify-content-between align-items-center">
    <div><h2 class="mb-0">Digital Products</h2><div class="text-muted">Downloads</div></div>
    <div class="d-flex gap-2">
        <a class="btn btn-secondary" target="_blank" asp-controller="DigitalDownloadsPublic" asp-action="Storefront" asp-route-storeId="@Model.StoreId">View store</a>
        <a class="btn btn-secondary" asp-action="Settings" asp-route-storeId="@Model.StoreId">Settings</a>
        <a class="btn btn-primary" asp-action="Product" asp-route-storeId="@Model.StoreId">Add product</a>
    </div>
</div>
<nav class="nav nav-pills gap-2 mb-4" aria-label="Digital product sections">
    <a class="nav-link active" aria-current="page" asp-controller="DigitalDownloadsAdmin" asp-action="Index" asp-route-storeId="@Model.StoreId">Downloads</a>
    <a class="nav-link" asp-controller="LicenseManagerAdmin" asp-action="Index" asp-route-storeId="@Model.StoreId">License keys</a>
</nav>
<partial name="_StatusMessage" />
<div class="row g-3 mb-4">
    <div class="col-md-4"><div class="bg-tile rounded p-3"><div class="text-muted">Products</div><div class="h3 mb-0">@Model.Products.Count</div></div></div>
    <div class="col-md-4"><div class="bg-tile rounded p-3"><div class="text-muted">Paid orders</div><div class="h3 mb-0">@Model.Orders.Count(o => o.Status == DigitalOrderStatus.Paid)</div></div></div>
    <div class="col-md-4"><div class="bg-tile rounded p-3"><div class="text-muted">Downloads served</div><div class="h3 mb-0">@Model.Orders.Sum(o => o.DownloadCount)</div></div></div>
</div>
<h4>Products</h4>
<div class="table-responsive mb-5"><table class="table align-middle"><thead><tr><th>Name</th><th>Storage</th><th>Price</th><th>Status</th><th></th></tr></thead><tbody>
@if (!Model.Products.Any()) { <tr><td colspan="5" class="text-muted py-4">Add your first product to publish the storefront.</td></tr> }
@foreach (var product in Model.Products) {
<tr><td><strong>@product.Name</strong><div class="small text-muted">/@product.Slug</div></td><td>@product.StorageKind</td><td>@DisplayFormatter.Currency(product.Price, Model.Settings.Currency)</td><td>@(product.Active ? "Published" : "Draft")</td><td class="text-end"><a class="btn btn-sm btn-secondary" asp-action="Product" asp-route-storeId="@Model.StoreId" asp-route-productId="@product.Id">Edit</a></td></tr>
}</tbody></table></div>
<h4>Recent orders</h4>
<div class="table-responsive"><table class="table align-middle"><thead><tr><th>Created</th><th>Order / invoice</th><th>Customer</th><th>Status</th><th>Downloads</th><th></th></tr></thead><tbody>
@if (!Model.Orders.Any()) { <tr><td colspan="6" class="text-muted py-4">No orders yet.</td></tr> }
@foreach (var order in Model.Orders) {
<tr><td>@order.CreatedAt.ToBrowserDate()</td><td><code>@order.Id[..8]</code>@if (order.InvoiceId is not null){<div><a asp-controller="UIInvoice" asp-action="Invoice" asp-route-invoiceId="@order.InvoiceId">@order.InvoiceId</a></div>}</td><td>@order.BuyerEmail</td><td>@order.Status</td><td>@order.DownloadCount / @order.MaxDownloads</td><td class="text-end">@if(order.Status == DigitalOrderStatus.Paid){<form method="post" asp-action="Revoke" asp-route-storeId="@Model.StoreId" asp-route-orderId="@order.Id"><button class="btn btn-sm btn-outline-danger">Revoke</button></form>}</td></tr>
}</tbody></table></div>
<div class="alert alert-info mt-4 mb-0">@Model.Settings.PromotionText <a href="https://makepay.io" target="_blank" rel="noopener">Enable 90+ currencies with MakePay</a>.</div>
